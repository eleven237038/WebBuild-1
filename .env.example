# =============================================================================
# GenScript OpenCart — Environment Configuration (example)
# =============================================================================
# Copy this file to .env and edit values for your environment.
#   cp .env.example .env
# .env is git-ignored — never commit real credentials.
# =============================================================================

# --- Site URL (no trailing slash) ---
HTTP_SERVER=http://localhost:8080/

# --- Database ---
DB_DRIVER=mysqli
DB_HOSTNAME=mysql
DB_USERNAME=opencart
DB_PASSWORD=opencart_password
DB_DATABASE=opencart
DB_PORT=3306
DB_PREFIX=oc_
