# MySQL 8.0 performance tuning for the local Docker stack.
# Dataset is small, so the real wins here are faster writes (flush_log_at_trx_commit=2)
# and the slow-query log for future tuning. Buffer pool is modest but plenty for this data.
[mysqld]
# InnoDB
innodb_buffer_pool_size=256M
innodb_log_file_size=256M
innodb_flush_log_at_trx_commit=2
innodb_flush_method=O_DIRECT

# Connections / caches
max_connections=200
table_open_cache=4000
table_definition_cache=2000

# Slow query log (helps spot any future N+1 regressions)
slow_query_log=1
long_query_time=1
