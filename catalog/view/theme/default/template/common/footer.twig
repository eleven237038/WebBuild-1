<!-- OpenCart scripts (kept for cart/wishlist popups) -->
{% for script in scripts %}
<script src="{{ script }}" type="text/javascript"></script>
{% endfor %}

<script type="text/javascript">
  var showAlert = function(type, content) {
    if (type == 'cart') {
      redirectButtonText = '{{ button_checkout }}';
      redirectButtonLocation = '{{ helper.url.link("checkout/cart") }}';
    } else if (type == 'wishlist') {
      redirectButtonText = '{{ button_wishlist }}';
      redirectButtonLocation = '{{ wishlist }}';
    } else if (type == 'compare') {
      redirectButtonText = '{{ button_compare }}';
      redirectButtonLocation = '{{ helper.url.link("product/compare") }}';
    }

    layer.open({
      title: '{{ text_layer_popup_title }}',
      skin: 'layer-alert',
      shadeClose: true,
      content: content,
      btn: [redirectButtonText, '{{ button_continue_shopping }}'],
      yes: function() {
        location = redirectButtonLocation;
      }
    });
  }
</script>

