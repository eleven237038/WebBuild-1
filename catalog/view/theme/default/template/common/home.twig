{{ header }}
<!-- ==========================================================================
 *  GenScript Homepage — Modern Science-Backed Landing Page
 *  10 Blocks: Hero → Stats → Bestsellers → Categories → Feature Compare
 *  → Reviews → Why Us Table → Education → FAQ → Money-Back Guarantee
 *  Brand Colors: Deep Navy #000B47 | Accent Green #00a651
 * ========================================================================== -->

<style>
/* ═══════ Homepage Block System ═══════ */
.home-block { width: 100%; padding: 80px 0; box-sizing: border-box; }
.home-block--dark  { background: #000B47; color: #ffffff; }
.home-block--light { background: #ffffff; color: #1a1a2e; }
.home-block--gray  { background: #f4f6f9; color: #1a1a2e; }
.home-block--green { background: #00a651; color: #ffffff; }
.home-wrap { max-width: 1260px; margin: 0 auto; padding: 0 32px; }

/* ═══════ BLOCK 1: Hero ═══════ */
.hero-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
.hero-title { font-family: "Figtree",sans-serif; font-weight: 900; font-size: 56px; line-height: 1.08; color: #000B47; margin: 0 0 18px; }
.hero-sub { font-size: 17px; color: #555; line-height: 1.6; margin: 0 0 28px; max-width: 480px; }
.hero-cta { display: inline-flex; align-items: center; gap: 8px; padding: 14px 32px; background: #00a651; color: #fff; font-weight: 700; font-size: 15px; border-radius: 6px; text-decoration: none; transition: background 0.2s; }
.hero-cta:hover { background: #008c44; color: #fff; text-decoration: none; }
.hero-payments { display: flex; gap: 12px; margin-top: 20px; }
.hero-payments span { padding: 4px 10px; background: #f0f2f5; border-radius: 4px; font-size: 12px; color: #666; }
.hero-right { display: flex; gap: 20px; align-items: center; justify-content: center; }
.hero-card { background: #000B47; border-radius: 16px; padding: 28px 22px; color: #fff; box-shadow: 0 20px 50px rgba(0,11,71,0.25); }
.hero-card h3 { font-size: 16px; margin: 0 0 8px; }
.hero-card .card-vial { width: 100px; height: 140px; margin: 10px auto; background: linear-gradient(180deg, #1a3a8a 0%, #0d1f5c 100%); border-radius: 12px; display: flex; align-items: flex-end; justify-content: center; padding-bottom: 10px; }

/* ═══════ BLOCK 2: Stats Bar ═══════ */
.stats-flex { display: flex; gap: 0; }
.stats-item { flex: 1; text-align: center; padding: 48px 20px; border-right: 1px solid rgba(255,255,255,0.12); }
.stats-item:last-child { border-right: none; }
.stats-num { font-family: "Figtree",sans-serif; font-weight: 900; font-size: 42px; margin: 0 0 4px; }
.stats-label { font-size: 13px; text-transform: uppercase; letter-spacing: 2px; opacity: 0.7; margin: 0; }

/* ═══════ BLOCK 3: Best Sellers Grid ═══════ */
.section-title { font-family: "Figtree",sans-serif; font-weight: 800; font-size: 32px; margin: 0 0 40px; }
.products-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
.product-card { background: #fff; border-radius: 12px; overflow: hidden; border: 1px solid #eee; transition: box-shadow 0.2s; }
.product-card:hover { box-shadow: 0 8px 30px rgba(0,0,0,0.08); }
.product-card-img { height: 200px; background: #f4f6f9; display: flex; align-items: center; justify-content: center; font-size: 60px; }
.product-card-body { padding: 18px; }
.product-card-body h3 { font-family: "Figtree",sans-serif; font-size: 15px; font-weight: 700; margin: 0 0 6px; }
.product-card-body .purity { display: inline-block; background: #e6f7ee; color: #00a651; font-size: 11px; font-weight: 700; padding: 3px 8px; border-radius: 4px; margin-bottom: 8px; }
.product-card-body .price { font-size: 20px; font-weight: 800; color: #000B47; margin: 0 0 12px; }
.btn-add-cart { display: block; width: 100%; padding: 10px 0; background: #00a651; color: #fff; border: none; border-radius: 6px; font-weight: 700; font-size: 13px; cursor: pointer; text-align: center; }
.btn-view-all { display: block; width: 100%; max-width: 360px; margin: 40px auto 0; padding: 14px 0; background: #00a651; color: #fff; border: none; border-radius: 6px; font-weight: 700; font-size: 15px; cursor: pointer; text-align: center; text-decoration: none; }
.trust-strip { display: flex; justify-content: center; gap: 60px; margin-top: 28px; }
.trust-item { display: flex; align-items: center; gap: 8px; font-size: 13px; color: #666; }
.trust-item i { font-size: 20px; color: #00a651; }

/* ═══════ BLOCK 4: Category Cards ═══════ */
.cat-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
.cat-card { background: #f4f6f9; border-radius: 10px; padding: 28px 22px; display: flex; align-items: center; justify-content: space-between; transition: transform 0.2s; text-decoration: none; color: #000B47; }
.cat-card:hover { transform: translateY(-3px); }
.cat-card span { font-weight: 700; font-size: 14px; }
.cat-card i { color: #00a651; font-size: 18px; }

/* ═══════ BLOCK 5: Proof Before Potency ═══════ */
.proof-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
.proof-title { font-family: "Figtree",sans-serif; font-weight: 900; font-size: 38px; line-height: 1.15; margin: 0 0 22px; }
.proof-list { list-style: none; padding: 0; margin: 0 0 24px; }
.proof-list li { padding: 10px 0; font-size: 15px; display: flex; align-items: center; gap: 10px; }
.proof-list li i { color: #00a651; font-size: 18px; }
.proof-card { background: #fff; border-radius: 14px; padding: 28px; box-shadow: 0 12px 40px rgba(0,0,0,0.1); text-align: center; max-width: 340px; }
.proof-card .sku { font-size: 12px; color: #999; margin: 0 0 4px; }
.proof-card .price-lg { font-size: 28px; font-weight: 900; color: #000B47; margin: 10px 0; }
.proof-card .btn-green { display: block; width: 100%; padding: 12px; background: #00a651; color: #fff; border: none; border-radius: 6px; font-weight: 700; font-size: 14px; cursor: pointer; }

/* ═══════ BLOCK 6: Reviews ═══════ */
.review-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
.review-card { background: #fff; border: 1px solid #eee; border-radius: 12px; padding: 28px; }
.review-stars { color: #f5a623; font-size: 14px; margin-bottom: 10px; }
.review-card h4 { font-family: "Figtree",sans-serif; font-weight: 700; font-size: 15px; margin: 0 0 8px; }
.review-card p { font-size: 13.5px; color: #555; line-height: 1.5; margin: 0 0 14px; }
.review-author { display: flex; align-items: center; gap: 10px; }
.review-author .avatar { width: 36px; height: 36px; border-radius: 50%; background: #ddd; display: flex; align-items: center; justify-content: center; font-size: 14px; color: #666; }
.review-author .name { font-size: 13px; font-weight: 600; }

/* ═══════ BLOCK 7: Why Researchers Choose Us ═══════ */
.why-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 50px; margin-bottom: 40px; }
.why-grid p { font-size: 14px; line-height: 1.7; color: #555; }
.compare-table { width: 100%; border-collapse: collapse; margin-top: 20px; }
.compare-table th { background: #000B47; color: #fff; padding: 12px 16px; text-align: left; font-size: 13px; font-weight: 700; text-transform: uppercase; }
.compare-table td { padding: 12px 16px; border-bottom: 1px solid #eee; font-size: 13px; }
.compare-table td:nth-child(2) { color: #00a651; font-weight: 700; }
.compare-table td:nth-child(3) { color: #999; }

/* ═══════ BLOCK 8: Education ═══════ */
.edu-text { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; }
.edu-text p { font-size: 14px; line-height: 1.75; color: #555; }

/* ═══════ BLOCK 9: FAQ ═══════ */
.faq-list details { border-bottom: 1px solid #e5e7eb; padding: 16px 0; }
.faq-list summary { font-family: "Figtree",sans-serif; font-weight: 700; font-size: 15px; cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; }
.faq-list summary::after { content: "+"; font-size: 22px; color: #00a651; }
.faq-list details[open] summary::after { content: "−"; }
.faq-list .faq-answer { padding-top: 10px; font-size: 14px; color: #555; line-height: 1.6; }

/* ═══════ BLOCK 10: Money-Back ═══════ */
.mb-flex { display: flex; align-items: center; justify-content: space-between; gap: 30px; }
.mb-title { font-family: "Figtree",sans-serif; font-weight: 900; font-size: 30px; line-height: 1.2; margin: 0; }
.mb-badge { background: #fff; color: #000B47; padding: 16px 28px; border-radius: 8px; font-weight: 800; font-size: 16px; white-space: nowrap; }

/* ═══════ Responsive ═══════ */
@media (max-width: 1024px) {
  .hero-grid, .proof-grid, .why-grid { grid-template-columns: 1fr; }
  .products-grid, .cat-grid, .review-grid { grid-template-columns: repeat(2, 1fr); }
  .stats-flex, .mb-flex { flex-direction: column; }
  .stats-item { border-right: none; border-bottom: 1px solid rgba(255,255,255,0.12); }
  .hero-title { font-size: 38px; }
  .edu-text { grid-template-columns: 1fr; }
}
@media (max-width: 640px) {
  .products-grid, .cat-grid, .review-grid { grid-template-columns: 1fr; }
  .home-block { padding: 48px 0; }
  .hero-title { font-size: 30px; }
  .mb-title { font-size: 22px; }
}
</style>

