{# ==========================================================================
 *  Product Card Component - 100% Data-Driven from MySQL
 *  Usage: {% include 'default/template/product/product_card.twig' with {'product': product} %}
 *  Card appearance is configurable from admin > 商品目录 > 商品卡片管理.
 *  When product.pcards is absent (e.g. inline related lists), defaults show all.
 * ========================================================================== #}
{% set pc = product.pcards is defined ? product.pcards : {
  'show_image': 1, 'show_name': 1, 'show_description': 1, 'show_price': 1,
  'show_wishlist': 1, 'show_badges': 1, 'show_add_button': 1,
  'image_height': 200, 'desc_length': 100, 'desc_clamp': 2,
  'name_font_size': 15, 'price_font_size': 22, 'add_btn_text': '+'
} %}
<div class="product-card">
  <!-- Dynamic Custom Tags -> parent_name: tag_name or tag_name -->
  {% if pc.show_badges and product.custom_tags is defined and product.custom_tags is not empty %}
    {% for tag in product.custom_tags %}
    <span class="pcard-badge-dynamic">{{ tag.parent_name is defined and tag.parent_name is not empty ? tag.parent_name ~ ': ' }}{{ tag.name }}</span>
    {% endfor %}
  {% endif %}

  <!-- Image -->
  {% if pc.show_image %}
  <a href="{{ product.href is defined ? product.href : '#' }}" class="pcard-img-wrap" style="text-decoration:none;display:flex;align-items:center;justify-content:center;height:{{ pc.image_height }}px;">
    {% if pc.show_wishlist %}
    <button class="pcard-wishlist" aria-label="Wishlist" onclick="event.preventDefault();event.stopPropagation();">
      <i class="fa-regular fa-heart"></i>
    </button>
    {% endif %}
    {% if product.thumb %}<img src="{{ product.thumb }}" alt="{{ product.name }}" loading="lazy">
    {% elseif product.image %}<img src="{{ product.image }}" alt="{{ product.name }}" loading="lazy">
    {% else %}<span style="font-size:60px;">🧪</span>{% endif %}
  </a>
  {% endif %}

  <!-- Card body -->
  <div class="pcard-body">
    {% if pc.show_name %}
    <a href="{{ product.href is defined ? product.href : '#' }}" style="text-decoration:none;color:inherit;"><h3 class="pcard-name" style="font-size:{{ pc.name_font_size }}px;">{{ product.name }}</h3></a>
    {% endif %}
    {% if pc.show_description %}
    <p class="pcard-desc" style="-webkit-line-clamp:{{ pc.desc_clamp }};">{{ product.description is defined ? product.description|striptags|slice(0, pc.desc_length) ~ '...' : '' }}</p>
    {% endif %}

    {% if pc.show_price or pc.show_add_button %}
    <div class="pcard-bottom">
      {% if pc.show_price %}<p class="pcard-price" style="font-size:{{ pc.price_font_size }}px;">{{ product.price is defined ? product.price : '' }}</p>{% endif %}
      {% if pc.show_add_button %}<button class="pcard-add" onclick="cart.add('{{ product.product_id }}', '1');">{{ pc.add_btn_text }}</button>{% endif %}
    </div>
    {% endif %}
  </div>
</div>
