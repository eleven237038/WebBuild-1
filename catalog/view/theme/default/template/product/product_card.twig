{# ==========================================================================
 *  Product Card Component — 100% Data-Driven from MySQL
 *  Usage: {% include 'default/template/product/product_card.twig' with {'product': product} %}
 * ========================================================================== #}
<div class="product-card">
  <!-- Dynamic Custom Tags → parent_name: tag_name or tag_name -->
  {% if product.custom_tags is defined and product.custom_tags is not empty %}
    {% for tag in product.custom_tags %}
    <span class="pcard-badge-dynamic">{{ tag.parent_name is defined and tag.parent_name is not empty ? tag.parent_name ~ ': ' }}{{ tag.name }}</span>
    {% endfor %}
  {% endif %}

  <!-- Image -->
  <a href="{{ product.href is defined ? product.href : '#' }}" class="pcard-img-wrap" style="text-decoration:none;display:flex;align-items:center;justify-content:center;">
    <button class="pcard-wishlist" aria-label="Wishlist" onclick="event.preventDefault();event.stopPropagation();">
      <i class="fa-regular fa-heart"></i>
    </button>
    {% if product.thumb %}<img src="{{ product.thumb }}" alt="{{ product.name }}" loading="lazy">
    {% elseif product.image %}<img src="{{ product.image }}" alt="{{ product.name }}" loading="lazy">
    {% else %}<span style="font-size:60px;">🧪</span>{% endif %}
  </a>

  <!-- Card body -->
  <div class="pcard-body">
    <a href="{{ product.href is defined ? product.href : '#' }}" style="text-decoration:none;color:inherit;"><h3 class="pcard-name">{{ product.name }}</h3></a>
    <p class="pcard-desc">{{ product.description is defined ? product.description|striptags|slice(0, 100) ~ '...' : '' }}</p>

    <!-- Price + Add -->
    <div class="pcard-bottom">
      <p class="pcard-price">{{ product.price is defined ? product.price : '' }}</p>
      <button class="pcard-add" onclick="cart.add('{{ product.product_id }}', '1');"><i class="fa-solid fa-plus"></i></button>
    </div>
  </div>
</div>
