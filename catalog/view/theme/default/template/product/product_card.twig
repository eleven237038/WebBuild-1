{# ==========================================================================
 *  GenScript — Shared Product Card Component
 *  Usage: {% include 'default/template/product/_partial_product_card.twig' with {'product': product} %}
 *  Entire image area is clickable → product.href
 * ========================================================================== #}
<div class="product-card">
  <!-- Dynamic Custom Tags — from Admin Tag Management -->
  {% if product.custom_tags is defined and product.custom_tags is not empty %}
    {% for tag in product.custom_tags %}
    <span class="pcard-badge-dynamic">{{ tag.name }}</span>
    {% endfor %}
  {% else %}
    <!-- Fallback default badges when no custom tags are assigned -->
    <span class="pcard-badge-pop" style="position:absolute;top:12px;left:12px;z-index:2;">★ POPULAR</span>
    <span class="pcard-badge-coa" style="position:absolute;top:12px;right:12px;z-index:2;">✓ COA</span>
  {% endif %}

  <!-- Image — full clickable area -->
  <a href="{{ product.href is defined ? product.href : '#' }}" class="pcard-img-wrap" style="text-decoration:none;display:flex;align-items:center;justify-content:center;">
    <button class="pcard-wishlist" aria-label="Wishlist" onclick="event.preventDefault();event.stopPropagation();">
      <i class="fa-regular fa-heart"></i>
    </button>
    {% if product.thumb %}
    <img src="{{ product.thumb }}" alt="{{ product.name }}" loading="lazy">
    {% else %}
    <span style="font-size:60px;">{% if product.emoji is defined %}{{ product.emoji }}{% else %}🧪{% endif %}</span>
    {% endif %}
  </a>

  <!-- Card body -->
  <div class="pcard-body">
    <a href="{{ product.href is defined ? product.href : '#' }}" style="text-decoration:none;color:inherit;"><h3 class="pcard-name">{{ product.name }}</h3></a>
    <p class="pcard-desc">{{ product.description is defined ? product.description|striptags|slice(0, 100) ~ '...' : 'Third-party tested — 99% by HPLC analysis with full COA documentation.' }}</p>

    <!-- Variants -->
    <div class="pcard-variants">
      <span class="pcard-var active">5MG</span>
      <span class="pcard-var">10MG</span>
      <span class="pcard-var">25MG</span>
    </div>

    <!-- Price + Add -->
    <div class="pcard-bottom">
      <div>
        <span class="pcard-price-label">STARTING FROM</span>
        <p class="pcard-price">{{ product.price is defined ? product.price : '$50.00' }}</p>
      </div>
      <button class="pcard-add" onclick="cart.add('{{ product.product_id }}', '1');"><i class="fa-solid fa-plus"></i> Add</button>
    </div>

    <!-- Shipping -->
    <p class="pcard-shipping">ships in &lt;24h</p>
  </div>
</div>
