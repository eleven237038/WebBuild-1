{# ==========================================================================
 *  Product Card Component - 100% Data-Driven from MySQL
 *  Usage: {% include 'default/template/product/product_card.twig' with {'product': product} %}
 *  Every caller passes a fully-resolved product from handleSingleProduct()
 *  (home / category / PDP related / bestseller / featured / latest modules),
 *  so pcards, show_* and *_value are always present - no bare-data fallbacks.
 *  Card appearance is configurable from admin > 商品目录 > 商品卡片管理.
 *  Content slots (image/name/description/price/badges) each map to a custom_tag
 *  field of the product's type; the mapped field's value feeds that slot
 *  (blank mapping = hide). Action buttons (wishlist/add) stay boolean toggles.
 * ========================================================================== #}
{% set pc = product.pcards %}
<div class="product-card" style="--pcard-primary:{{ pc.primary_color }};--pcard-name-color:{{ pc.name_color }};--pcard-price-color:{{ pc.price_color }};">
  {% if product.show_badges and product.badge_value is not empty %}
  <span class="pcard-badge-dynamic">{{ product.badge_value }}</span>
  {% endif %}

  {% if product.show_image %}
  <a href="{{ product.href }}" class="pcard-img-wrap" style="text-decoration:none;display:flex;align-items:center;justify-content:center;height:{{ pc.image_height }}px;">
    {% if pc.show_wishlist %}
    <button class="pcard-wishlist" aria-label="Wishlist" onclick="event.preventDefault();event.stopPropagation();">
      <i class="fa-regular fa-heart"></i>
    </button>
    {% endif %}
    {% if product.image_value %}
    <img src="{{ product.image_value }}" alt="{{ product.name }}" loading="lazy">
    {% else %}
    <span style="font-size:60px;">🧪</span>
    {% endif %}
  </a>
  {% endif %}

  <div class="pcard-body">
    {% if product.show_name %}
    <a href="{{ product.href }}" style="text-decoration:none;color:inherit;"><h3 class="pcard-name" style="font-size:{{ pc.name_font_size }}px;">{{ product.name_value }}</h3></a>
    {% endif %}
    {% if product.show_description %}
    <p class="pcard-desc" style="-webkit-line-clamp:{{ pc.desc_clamp }};">{{ product.description_value|striptags|slice(0, pc.desc_length) ~ '...' }}</p>
    {% endif %}

    {% if product.show_price or pc.show_add_button %}
    <div class="pcard-bottom">
      {% if product.show_price %}<p class="pcard-price" style="font-size:{{ pc.price_font_size }}px;">{{ product.price_value }}</p>{% endif %}
      {% if pc.show_add_button %}<button class="pcard-add" onclick="cart.add('{{ product.product_id }}', '1');">{{ pc.add_btn_text }}</button>{% endif %}
    </div>
    {% endif %}
  </div>
</div>
