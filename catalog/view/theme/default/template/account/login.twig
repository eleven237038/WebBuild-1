{{ header }}
<!-- ==========================================================================
 *  GenScript — Login Page Redesign (Split Card Layout)
 *  Left: Brand area (deep blue + geometric overlay)
 *  Right: Login form (white card with all OpenCart bindings intact)
 * ========================================================================== -->
<div class="login-page-wrapper">

  <!-- ════ Top Bar: Logo + Contact ════ -->
  <div class="login-top-bar">
    <a href="{{ home }}" class="login-top-logo">
      <img src="catalog/view/theme/default/image/logo-icon.svg" alt="" width="36" height="36">
      <span>GenScript</span>
    </a>
    <a href="{{ contact }}" class="login-top-contact">
      <i class="fa-solid fa-phone"></i> CONTACT US
    </a>
  </div>

  <!-- ════ Split Card ════ -->
  <div class="login-card-wrapper">
    <div class="login-card">

      {# ── LEFT: Brand Showcase ── #}
      <div class="login-brand">
        <div class="login-brand-geo"></div>
        <div class="login-brand-geo login-brand-geo--2"></div>
        <div class="login-brand-content">
          <h1 class="login-brand-title">Welcome to<br>GenScript</h1>
          <p class="login-brand-sub">Start a pleasant buying journey</p>
        </div>
      </div>

      {# ── RIGHT: Login Form ── #}
      <div class="login-form-side">

        {% if success %}
        <div class="login-alert login-alert--success"><i class="fa fa-check-circle"></i> {{ success }}</div>
        {% endif %}
        {% if error_warning %}
        <div class="login-alert login-alert--error"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}</div>
        {% endif %}

        <h2 class="login-form-title">Please Sign in</h2>

        <form action="{{ action }}" method="post" enctype="multipart/form-data">

          {# Email / Account #}
          <div class="login-field">
            <label class="login-label" for="input-email">Email Address / Account No.</label>
            <input type="text" name="email" value="{{ email }}" id="input-email"
                   class="login-input" placeholder="Enter your email or account number" autocomplete="email">
          </div>

          {# Password with eye toggle #}
          <div class="login-field">
            <div class="login-password-header">
              <label class="login-label" for="input-password">Password</label>
              <a href="{{ forgotten }}" class="login-forgot-link">Forgot your password?</a>
            </div>
            <div class="login-password-wrap">
              <input type="password" name="password" value="{{ password }}" id="input-password"
                     class="login-input login-input--password" placeholder="Enter your password" autocomplete="current-password">
              <button type="button" class="login-eye-toggle" id="btn-toggle-password" aria-label="Toggle password visibility">
                <i class="fa-regular fa-eye-slash" id="icon-password"></i>
              </button>
            </div>
          </div>

          {# Captcha #}
          <div class="login-field">
            {{ captcha }}
          </div>

          {# Hidden redirect #}
          {% if redirect %}
          <input type="hidden" name="redirect" value="{{ redirect }}">
          {% endif %}

          {# Hidden type field — preserve original OpenCart mobile/email tab logic #}
          <input type="hidden" name="type" value="email">

          {# Submit #}
          <button type="submit" class="login-btn-submit">Sign In</button>
        </form>

        {# Social login #}
        <div class="login-social-row">
          <span class="login-social-label">Login With</span>
          <div class="login-social-icons">
            <a href="#" class="login-social-icon" title="Facebook"><i class="fa-brands fa-facebook-f"></i></a>
            <a href="#" class="login-social-icon" title="LinkedIn"><i class="fa-brands fa-linkedin-in"></i></a>
            <a href="#" class="login-social-icon" title="Google"><i class="fa-brands fa-google"></i></a>
          </div>
        </div>

        {# Register CTA #}
        <div class="login-register-row">
          <p class="login-register-text">New to GenScript?</p>
          <a href="{{ register }}" class="login-btn-register">Register</a>
        </div>

      </div>

    </div>
  </div>

</div>

{# ════ Password Toggle JS ════ #}
<script>
(function() {
  var btn = document.getElementById('btn-toggle-password');
  var input = document.getElementById('input-password');
  var icon = document.getElementById('icon-password');
  if (btn && input && icon) {
    btn.addEventListener('click', function() {
      if (input.type === 'password') {
        input.type = 'text';
        icon.className = 'fa-regular fa-eye';
      } else {
        input.type = 'password';
        icon.className = 'fa-regular fa-eye-slash';
      }
    });
  }
})();
</script>

{# ════ Restyle captcha to match our design ════ #}
<script>
(function() {
  // Wrap captcha image + input into a flex row for our layout
  var capImg = document.querySelector('.captcha-img img, img[src*="captcha"]');
  var capInput = document.querySelector('input[name="captcha"]');
  if (capImg && capInput) {
    capImg.style.height = '44px';
    capImg.style.borderRadius = '4px';
    capImg.style.border = '1px solid #d1d5db';
    capInput.classList.add('login-input');
    // Remove old Bootstrap wrappers
    var wrapper = capInput.closest('.input-captcha-wrap');
    if (wrapper) wrapper.style.display = 'flex';
    if (wrapper) wrapper.style.gap = '10px';
    var fieldset = capInput.closest('fieldset');
    if (fieldset) fieldset.style.cssText = 'border:none;padding:0;margin:0';
  }
})();
</script>

{{ footer }}
