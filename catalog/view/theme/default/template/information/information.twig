  background-size: 40px 40px;
  padding: 100px 0; text-align: center;
  position: relative;
}
.about-hero::before {
  content: "";
  position: absolute; top: -120px; left: 50%; transform: translateX(-50%);
  width: 500px; height: 300px;
  background: radial-gradient(ellipse at center, rgba(0,166,81,0.08) 0%, transparent 70%);
  pointer-events: none;
}
.about-tag { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; color: var(--primary-green); margin: 0 0 14px; }
.about-hero-title { font-family: "Figtree",sans-serif; font-weight: 900; font-size: 56px; color: #1a1a2e; text-transform: uppercase; line-height: 1.12; margin: 0 0 18px; letter-spacing: -1px; }
.about-hero-sub { font-size: 17px; color: #666; margin: 0 auto; max-width: 620px; line-height: 1.55; }

/* ═══════ BLOCK 2: Dark split layout ═══════ */
.about-dark { background: var(--bg-navy); color: #ffffff; padding: 80px 0; }
.about-split { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: start; }
.about-tag--dark { color: var(--primary-green); }
.about-dark-title { font-family: "Figtree",sans-serif; font-weight: 900; font-size: 36px; text-transform: uppercase; line-height: 1.15; margin: 0 0 22px; color: #ffffff; }
.about-dark-text { font-size: 14.5px; color: rgba(255,255,255,0.72); line-height: 1.65; margin: 0 0 18px; }
.about-quote { border-left: 3px solid var(--primary-green); padding-left: 15px; font-style: italic; color: #ffffff; font-size: 13.5px; line-height: 1.55; margin: 22px 0 0; }

/* ═══════ 2×2 Cards ═══════ */
.about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: rgba(255,255,255,0.08); border-radius: 8px; overflow: hidden; }
.about-card { background: rgba(255,255,255,0.05); padding: 36px 32px; }
.about-card-num { font-family: "Figtree",sans-serif; font-weight: 900; font-size: 36px; color: var(--primary-green); margin: 0 0 2px; line-height: 1; }
.about-card-label { font-size: 10.5px; color: rgba(255,255,255,0.4); text-transform: uppercase; letter-spacing: 1.5px; margin: 0 0 8px; }
