<div class="about-page">
  <!-- BLOCK 1: Hero -->
  <section class="about-section about-hero">
    <div class="about-wrap">
      <p class="about-tag">// ABOUT</p>
      <h1 class="about-hero-title">BUILT ON STANDARDS,<br>NOT SHORTCUTS</h1>
      <p class="about-hero-sub">Sparta Labs delivers premium, lab-tested research peptides for those who demand the highest standards.</p>
    </div>
  </section>

  <!-- BLOCK 2: Dark Split -->
  <section class="about-section about-dark">
    <div class="about-wrap">
      <div class="about-split">
        <!-- Left: Text -->
        <div>
          <p class="about-tag about-tag--dark">// ABOUT</p>
          <h2 class="about-dark-title">BUILT ON STANDARDS,<br>NOT SHORTCUTS</h2>
          <p class="about-dark-text">Sparta Labs delivers premium, lab-tested research peptides for those who demand the highest standards. Every product is third-party tested and backed by a Certificate of Analysis to verify purity, identity, and authenticity.</p>
          <p class="about-dark-text">We believe researchers deserve full transparency into what they're working with. That's why every batch is independently verified, every COA is publicly available, and every product meets or exceeds 99% purity standards.</p>
          <p class="about-quote">All Sparta Labs products are for research use only and are not intended for human or veterinary use.</p>
        </div>
        <!-- Right: 2×2 Cards -->
        <div class="about-grid">
          <div class="about-card"><p class="about-card-num">01</p><p class="about-card-label">THIRD-PARTY TESTED</p><p class="about-card-text">Every batch independently verified by accredited laboratories for purity and identity.</p></div>
          <div class="about-card"><p class="about-card-num">02</p><p class="about-card-label">FULL TRANSPARENCY</p><p class="about-card-text">Full Certificates of Analysis available for every product, every batch — no exceptions.</p></div>
          <div class="about-card"><p class="about-card-num">03</p><p class="about-card-label">99% PURITY</p><p class="about-card-text">Rigorous quality control ensuring research-grade compounds that meet the highest standards.</p></div>
          <div class="about-card"><p class="about-card-num">04</p><p class="about-card-label">FAST SHIPPING</p><p class="about-card-text">Temperature-controlled packaging with discreet, fast shipping across the United States.</p></div>
        </div>
      </div>
    </div>
  </section>
</div>

{% elseif information_id == 8 %}
{# ═══════════════════════════════════════════════ ARTICLES PAGE ═══════════ #}
<style>
.articles-page { width: 100%; overflow-x: hidden; background: #f8f9fa; }
.articles-wrap { max-width: 1400px; margin: 0 auto; padding: 0 24px; }

/* ═══════ BLOCK 1: Hero with grid + green glow ═══════ */
.articles-hero {
  background-color: #ffffff;
  background-image:
    linear-gradient(rgba(0,11,71,0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0,11,71,0.03) 1px, transparent 1px);
  background-size: 40px 40px;
  padding: 60px 0; text-align: center;
  position: relative;
}
.articles-hero::before {
  content: ""; position: absolute; top: -80px; left: 50%; transform: translateX(-50%);
  width: 400px; height: 200px;
  background: radial-gradient(ellipse at center, rgba(0,166,81,0.06) 0%, transparent 70%);
  pointer-events: none;
}
.articles-tag { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; color: var(--primary-green); margin: 0 0 12px; }
.articles-hero-title { font-family: "Figtree",sans-serif; font-weight: 900; font-size: 48px; color: var(--bg-navy); text-transform: uppercase; line-height: 1.12; margin: 0 0 14px; }
.articles-hero-sub { font-size: 16px; color: #666; margin: 0; }

/* ═══════ BLOCK 2: Sidebar + Grid ═══════ */
.articles-main { display: flex; gap: 40px; max-width: 1400px; margin: 40px auto; padding: 0 24px; }

/* --- Sidebar --- */
.articles-sidebar { width: 260px; flex-shrink: 0; }
.articles-sidebar-inner { position: sticky; top: 100px; }
.articles-search { position: relative; margin-bottom: 24px; }
.articles-search input { width: 100%; height: 42px; padding: 0 14px 0 38px; border: 1px solid #e0e0e0; border-radius: 8px; font-size: 13px; color: #333; outline: none; box-sizing: border-box; }
.articles-search input:focus { border-color: var(--primary-green); }
.articles-search i { position: absolute; left: 13px; top: 50%; transform: translateY(-50%); color: #bbb; font-size: 13px; }
.articles-sidebar h4 { font-family: "Figtree",sans-serif; font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: #999; margin: 0 0 12px; }
.articles-cat-list { list-style: none; padding: 0; margin: 0 0 24px; }
.articles-cat-list li { margin-bottom: 6px; }
.articles-cat-list label { display: flex; align-items: center; gap: 8px; font-size: 13px; color: #555; cursor: pointer; }
.articles-cat-list input[type="checkbox"] { accent-color: var(--primary-green); width: 16px; height: 16px; }
.articles-tags { display: flex; flex-wrap: wrap; gap: 8px; }
.articles-tag-pill { display: inline-block; padding: 5px 12px; background: #f0f2f5; border-radius: 16px; font-size: 11px; color: #666; text-decoration: none; transition: background 0.15s, color 0.15s; }
.articles-tag-pill:hover { background: var(--primary-green); color: #fff; }

/* --- Article Grid --- */
.articles-grid-wrap { flex: 1; min-width: 0; }
.articles-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 32px; }

/* --- Article Card --- */
.article-card { display: flex; flex-direction: column; background: #fff; border-radius: 8px; overflow: hidden; transition: box-shadow 0.2s; }
.article-card:hover { box-shadow: 0 4px 20px rgba(0,0,0,0.06); }
.article-card-img-wrap { position: relative; overflow: hidden; border-radius: 8px 8px 0 0; height: 200px; background: var(--bg-navy); display: flex; align-items: center; justify-content: center; }
.article-card-img-wrap .article-emoji { font-size: 60px; }
.article-card-badge { position: absolute; bottom: 0; left: 0; background: var(--primary-green); color: #fff; font-size: 10px; font-weight: 700; padding: 5px 14px; letter-spacing: 1px; text-transform: uppercase; }
.article-card-body { padding: 18px; flex-grow: 1; display: flex; flex-direction: column; }
.article-card-body h3 { font-family: "Figtree",sans-serif; font-weight: 700; font-size: 17px; color: var(--bg-navy); margin: 0 0 8px; line-height: 1.35; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.article-card-body p { font-size: 13.5px; color: #666; line-height: 1.55; margin: 0 0 16px; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
.article-card-meta { display: flex; justify-content: space-between; align-items: center; margin-top: auto; border-top: 1px solid #eee; padding-top: 12px; }
.article-card-date { font-size: 11px; color: #aaa; }
.article-card-readmore { font-size: 12px; font-weight: 700; color: var(--primary-green) !important; text-decoration: none; }
.article-card-readmore:hover { text-decoration: underline; }

/* --- Pagination --- */
.articles-pagination { display: flex; justify-content: center; gap: 8px; margin: 48px 0 60px; }
.articles-pagination a, .articles-pagination span { display: inline-flex; align-items: center; justify-content: center; width: 40px; height: 40px; border-radius: 8px; font-size: 13px; font-weight: 600; text-decoration: none; border: 1px solid #e0e0e0; color: #666; background: #fff; transition: all 0.15s; }
.articles-pagination a:hover { border-color: var(--primary-green); color: var(--primary-green); }
.articles-pagination .active { border-color: var(--primary-green); color: var(--primary-green); background: #e6f7ee; font-weight: 800; }

/* ═══════ Responsive ═══════ */
@media (max-width: 1024px) { .articles-main { flex-direction: column; } .articles-sidebar { width: 100%; } .articles-sidebar-inner { position: static; } .articles-hero-title { font-size: 34px; } }
@media (max-width: 640px) { .articles-grid { grid-template-columns: 1fr; } .articles-hero-title { font-size: 26px; } .articles-wrap { padding: 0 16px; } .articles-main { padding: 0 16px; } }
</style>

<div class="articles-page">
  <!-- BLOCK 1: Hero -->
  <section class="articles-hero">
    <div class="articles-wrap">
      <p class="articles-tag">// ARTICLES</p>
      <h1 class="articles-hero-title">PEPTIDE RESEARCH LIBRARY</h1>
      <p class="articles-hero-sub">Explore the latest findings and clinical data.</p>
    </div>
  </section>

  <!-- BLOCK 2: Sidebar + Grid -->
  <div class="articles-main">
    <!-- Sidebar -->
    <aside class="articles-sidebar">
      <div class="articles-sidebar-inner">
        <div class="articles-search">
          <i class="fa-solid fa-magnifying-glass"></i>
          <input type="text" placeholder="Search...">
        </div>
        <h4>Categories</h4>
        <ul class="articles-cat-list">
          <li><label><input type="checkbox" checked> Peptide Research</label></li>
          <li><label><input type="checkbox"> HPLC Analysis</label></li>
          <li><label><input type="checkbox"> Mass Spectrometry</label></li>
          <li><label><input type="checkbox"> Clinical Studies</label></li>
          <li><label><input type="checkbox"> Lab Techniques</label></li>
          <li><label><input type="checkbox"> Quality Standards</label></li>
        </ul>
        <h4>Popular Tags</h4>
        <div class="articles-tags">
          <a href="#" class="articles-tag-pill">BPC-157</a>
          <a href="#" class="articles-tag-pill">TB-500</a>
          <a href="#" class="articles-tag-pill">HPLC</a>
          <a href="#" class="articles-tag-pill">COA</a>
          <a href="#" class="articles-tag-pill">Purity</a>
          <a href="#" class="articles-tag-pill">Semaglutide</a>
          <a href="#" class="articles-tag-pill">Research</a>
          <a href="#" class="articles-tag-pill">Peptides</a>
        </div>
      </div>
    </aside>

    <!-- Article Grid -->
    <div class="articles-grid-wrap">
      <div class="articles-grid">
        {% set articles = [
          {'badge':'LATEST','title':'The Complete Guide to HPLC Testing for Research Peptides','date':'Oct 24, 2025','summary':'High-Performance Liquid Chromatography remains the gold standard for verifying peptide purity in research settings. This guide covers methodology, interpretation of results, and how to use COA data effectively.','emoji':'🔬'},
          {'badge':'RESEARCH','title':'BPC-157: Mechanisms of Action and Current Clinical Understanding','date':'Sep 18, 2025','summary':'An in-depth review of the pentadecapeptide BPC-157, examining its proposed mechanisms of action, preclinical data, and the current state of research literature.','emoji':'💊'},
          {'badge':'GUIDE','title':'Understanding Mass Spectrometry for Peptide Verification','date':'Aug 05, 2025','summary':'Mass spectrometry provides molecular-level confirmation of peptide identity. Learn how MS data complements HPLC results to create a complete analytical profile of research compounds.','emoji':'⚗️'},
          {'badge':'LATEST','title':'Cold-Chain Logistics: Best Practices for Peptide Storage and Shipping','date':'Jul 22, 2025','summary':'Temperature control during storage and transit is critical for maintaining peptide integrity. This article covers lyophilized powder stability, optimal storage temperatures, and shipping protocols.','emoji':'🧊'},
          {'badge':'RESEARCH','title':'Semaglutide and Tirzepatide: Comparative Analysis for Metabolic Research','date':'Jun 14, 2025','summary':'A detailed comparison of the two leading GLP-1 receptor agonists for research applications, including purity standards, HPLC profiles, and batch-to-batch consistency data.','emoji':'🧪'},
          {'badge':'GUIDE','title':'Endotoxin Testing in Peptide Research: Why It Matters','date':'May 30, 2025','summary':'Limulus Amebocyte Lysate (LAL) testing ensures peptide samples are free from bacterial endotoxin contamination. Essential reading for cell-based and in-vivo research applications.','emoji':'🛡️'}
        ] %}
        {% for article in articles %}
        <article class="article-card">
          <div class="article-card-img-wrap">
            <span class="article-emoji">{{ article.emoji }}</span>
            <span class="article-card-badge">{{ article.badge }}</span>
          </div>
          <div class="article-card-body">
            <h3>{{ article.title }}</h3>
            <p>{{ article.summary }}</p>
            <div class="article-card-meta">
              <span class="article-card-date">{{ article.date }}</span>
              <a href="#" class="article-card-readmore">Read More →</a>
            </div>
          </div>
        </article>
        {% endfor %}
      </div>

      <!-- BLOCK 3: Pagination -->
      <div class="articles-pagination">
        <span>←</span>
        <span class="active">1</span>
        <a href="#">2</a>
        <a href="#">3</a>
        <a href="#">→</a>
      </div>
    </div>
  </div>
</div>

{% else %}
