{{ header }}
<!-- ==========================================================================
 *  InsightWellnessLab - Contact Us Page (spartalabs.net/us/contact style)
 *  Block 1: Hero (grid + green glow, "/ Contact" crumb, tag, title, sub)
 *  Block 2: Section head "Contact details & message form"
 *  Block 3: Split — Left (icon info cards: Email / Hours / Location)
 *                     Right (form card: Name / Email / Subject / Message)
 *  Brand: Deep Navy var(--bg-navy) | Accent Green var(--primary-green)
 *  OpenCart bindings preserved: action, name, email, enquiry, subject, captcha, error_*
 * ========================================================================== -->
<style>
/* ═══════ Page ═══════ */
.contact-page { width: 100%; overflow-x: hidden; }
.contact-wrap { max-width: 1200px; margin: 0 auto; padding: 0 32px; }

/* ═══════ BLOCK 1: Hero (grid + green glow) ═══════ */
.contact-hero {
  background-color: #ffffff;
  background-image:
    linear-gradient(rgba(0,11,71,0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0,11,71,0.03) 1px, transparent 1px);
  background-size: 40px 40px;
  padding: 72px 0 64px; text-align: center;
  position: relative;
}
.contact-hero::before {
  content: ""; position: absolute; top: -120px; left: 50%; transform: translateX(-50%);
  width: 560px; height: 280px;
  background: radial-gradient(ellipse at center, rgba(16,185,129,0.10) 0%, transparent 70%);
  pointer-events: none;
}
.contact-crumb {
  font-size: 12px; font-weight: 700; text-transform: uppercase;
  letter-spacing: 2px; color: #9aa3b2; margin: 0 0 22px;
}
.contact-crumb a { color: #9aa3b2; text-decoration: none; transition: color 0.2s; }
.contact-crumb a:hover { color: var(--primary-green); }
.contact-crumb .crumb-sep { margin: 0 8px; opacity: 0.6; }
.contact-crumb .crumb-current { color: var(--bg-navy); }

.contact-tag {
  font-size: 12px; font-weight: 700; text-transform: uppercase;
  letter-spacing: 2px; color: var(--primary-green); margin: 0 0 14px;
}
.contact-hero-title {
  font-family: "Figtree",sans-serif; font-weight: 900; font-size: 56px;
  color: var(--bg-navy); text-transform: uppercase; line-height: 1.1;
  margin: 0 0 16px;
}
.contact-hero-sub {
  font-size: 16px; color: #666; margin: 0 auto; max-width: 540px; line-height: 1.55;
}

/* ═══════ Alerts ═══════ */
.contact-alert {
  max-width: 760px; margin: 20px auto 0; padding: 14px 20px;
  border-radius: 8px; font-size: 14px; font-weight: 600; text-align: center;
}
.contact-alert--ok  { background: #e6f7ee; color: #166534; border: 1px solid #bbf7d0; }
.contact-alert--err { background: #fef2f2; color: #991b1b; border: 1px solid #fecaca; }

/* ═══════ BLOCK 2: Section head ═══════ */
.contact-section-head { text-align: center; max-width: 760px; margin: 0 auto; padding: 64px 32px 12px; }
.contact-section-title {
  font-family: "Figtree",sans-serif; font-weight: 800; font-size: 30px;
  color: var(--bg-navy); margin: 0; line-height: 1.2;
}

/* ═══════ BLOCK 3: Split layout ═══════ */
.contact-main {
  max-width: 1200px; margin: 0 auto; padding: 36px 32px 88px;
  display: grid; grid-template-columns: 4fr 6fr; gap: 56px;
  align-items: start;
}

/* --- Left: Contact Info cards --- */
.contact-info { display: flex; flex-direction: column; gap: 16px; }
.contact-info-card {
  display: flex; align-items: flex-start; gap: 16px;
  background: #ffffff; border: 1px solid #eef1f6; border-radius: 12px;
  padding: 20px 22px; transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
}
.contact-info-card:hover {
  border-color: #d6efe4; transform: translateY(-2px);
  box-shadow: 0 10px 30px rgba(15,23,42,0.06);
}
.contact-info-ic {
  flex: 0 0 44px; width: 44px; height: 44px;
  display: flex; align-items: center; justify-content: center;
  background: rgba(16,185,129,0.10); color: var(--primary-green);
  border-radius: 10px; font-size: 18px;
}
.contact-info-body { min-width: 0; }
.contact-info-label {
  font-size: 11px; font-weight: 700; text-transform: uppercase;
  letter-spacing: 1.5px; color: #9aa3b2; margin: 2px 0 6px;
}
.contact-info-value {
  font-size: 15px; color: var(--bg-navy); font-weight: 600; margin: 0; line-height: 1.5;
  word-break: break-word;
}
.contact-info-value a { color: var(--bg-navy); text-decoration: none; transition: color 0.2s; }
.contact-info-value a:hover { color: var(--primary-green); }
.contact-info-note {
  display: flex; align-items: center; gap: 10px;
  margin-top: 4px; padding: 14px 22px 0;
  font-size: 13px; color: #64748b; line-height: 1.5;
}
.contact-info-note i { color: var(--primary-green); font-size: 16px; }

/* --- Social links row (联系方式目录 social accounts) --- */
.contact-social-row { display: flex; flex-wrap: wrap; gap: 12px; }
.contact-social-link {
  display: inline-flex; align-items: center; justify-content: center;
  width: 40px; height: 40px; border-radius: 9px;
  background: rgba(16,185,129,0.10); color: var(--primary-green);
  font-size: 18px; text-decoration: none;
  transition: background 0.2s, color 0.2s, transform 0.15s, box-shadow 0.2s;
}
.contact-social-link:hover {
  background: var(--primary-green); color: #ffffff; transform: translateY(-2px);
  box-shadow: 0 8px 18px rgba(16,185,129,0.28);
}

/* --- Right: Form card --- */
.contact-form-card {
  background: #ffffff; border: 1px solid #eef1f6; border-radius: 16px;
  padding: 36px; box-shadow: 0 16px 50px rgba(15,23,42,0.06);
}
.contact-row { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
.contact-field { margin-bottom: 20px; }
.contact-field-label {
  display: block; font-size: 11px; font-weight: 700; text-transform: uppercase;
  letter-spacing: 1.5px; color: #9aa3b2; margin: 0 0 7px;
}
.contact-input {
  display: block; width: 100%; padding: 12px 16px;
  border: 1px solid #e2e8f0; border-radius: 8px;
  font-family: "Figtree",sans-serif; font-size: 14px; color: #1a1a2e;
  background: #ffffff; outline: none; box-sizing: border-box;
  transition: border-color 0.2s, box-shadow 0.2s;
}
.contact-input::placeholder { color: #b3bac6; font-size: 13px; }
.contact-input:focus {
  border-color: var(--primary-green);
  box-shadow: 0 0 0 3px rgba(16,185,129,0.12);
}
.contact-textarea { min-height: 160px; resize: vertical; }
.contact-error {
  display: block; font-size: 12px; color: #dc2626; margin-top: 5px; font-weight: 600;
}

/* Captcha wrapper — neutralise any chrome the captcha fragment brings */
.contact-field fieldset { border: none; padding: 0; margin: 0; }
.contact-field .form-group { margin-bottom: 0; }

/* Submit button */
.contact-btn-submit {
  display: inline-flex; align-items: center; gap: 10px;
  padding: 14px 34px; background: var(--primary-green); color: #ffffff;
  border: none; border-radius: 8px;
  font-family: "Figtree",sans-serif; font-size: 15px; font-weight: 700;
  cursor: pointer; letter-spacing: 0.5px; text-transform: uppercase;
  transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
  box-shadow: 0 8px 20px rgba(16,185,129,0.22);
}
.contact-btn-submit:hover { background: #01926a; transform: translateY(-1px); }
.contact-btn-submit:active { transform: translateY(0); }
.contact-btn-submit i { font-size: 13px; }
.contact-form-foot {
  margin: 16px 0 0; font-size: 12px; color: #94a0b2; text-align: center;
}

/* ═══════ Responsive ═══════ */
@media (max-width: 980px) {
  .contact-main { grid-template-columns: 1fr; gap: 36px; }
  .contact-hero-title { font-size: 40px; }
}
@media (max-width: 640px) {
  .contact-hero { padding: 52px 0 44px; }
  .contact-hero-title { font-size: 30px; }
  .contact-section-head { padding: 48px 24px 8px; }
  .contact-section-title { font-size: 24px; }
  .contact-wrap, .contact-main { padding-left: 20px; padding-right: 20px; }
  .contact-main { padding-top: 28px; padding-bottom: 64px; }
  .contact-row { grid-template-columns: 1fr; gap: 0; }
  .contact-form-card { padding: 26px 22px; }
  .contact-btn-submit { width: 100%; justify-content: center; }
}
</style>

<div class="contact-page">

  <!-- ═══════ BLOCK 1: Hero ═══════ -->
  <section class="contact-hero">
    <div class="contact-wrap">
      <p class="contact-crumb">
        <a href="{{ home }}">Home</a>
        <span class="crumb-sep">/</span>
        <span class="crumb-current">Contact</span>
      </p>
      <p class="contact-tag">// CONTACT</p>
      <h1 class="contact-hero-title">Get In Touch</h1>
      <p class="contact-hero-sub">Reach out about products, COAs, partnerships, or anything else.</p>
    </div>
  </section>

  <!-- ═══════ Success / warning alert (if any) ═══════ -->
  {% if success %}
  <div class="contact-alert contact-alert--ok">{{ success }}</div>
  {% endif %}
  {% if error_warning %}
  <div class="contact-alert contact-alert--err">{{ error_warning }}</div>
  {% endif %}

  <!-- ═══════ BLOCK 2: Section head ═══════ -->
  <div class="contact-section-head">
    <p class="contact-tag">// REACH US</p>
    <h2 class="contact-section-title">Contact details &amp; message form</h2>
  </div>

  <!-- ═══════ BLOCK 3: Split Layout ═══════ -->
  <div class="contact-main">

    <!-- Left: Contact Info (config-driven, InsightWellnessLab) -->
    <div class="contact-info">

      {% if telephone %}
      <div class="contact-info-card">
        <div class="contact-info-ic"><i class="fa-solid fa-phone"></i></div>
        <div class="contact-info-body">
          <p class="contact-info-label">Phone</p>
          <p class="contact-info-value"><a href="tel:{{ telephone|replace({' ':''}) }}">{{ telephone }}</a></p>
        </div>
      </div>
      {% endif %}

      <div class="contact-info-card">
        <div class="contact-info-ic"><i class="fa-solid fa-envelope"></i></div>
        <div class="contact-info-body">
          <p class="contact-info-label">Email</p>
          <p class="contact-info-value">
            {% if store_email %}<a href="mailto:{{ store_email }}">{{ store_email }}</a>{% else %}<a href="mailto:support@insightwellnesslab.com">support@insightwellnesslab.com</a>{% endif %}
          </p>
        </div>
      </div>

      {% if socials %}
      <div class="contact-info-card">
        <div class="contact-info-ic"><i class="fa-solid fa-share-nodes"></i></div>
        <div class="contact-info-body">
          <p class="contact-info-label">Connect</p>
          <p class="contact-info-value contact-social-row">
            {% for s in socials %}
            <a href="{{ s.url }}" target="_blank" rel="noopener noreferrer" class="contact-social-link" title="{{ s.label }}"><i class="{{ s.icon }}"></i></a>
            {% endfor %}
          </p>
        </div>
      </div>
      {% endif %}

      <div class="contact-info-note">
        <i class="fa-solid fa-shield-halved"></i>
        <span>We typically respond within 24 hours. For order-specific questions, include your order number.</span>
      </div>
    </div>

    <!-- Right: Contact Form (OpenCart bindings intact) -->
    <div class="contact-form-card">

      <form action="{{ action }}" method="post" enctype="multipart/form-data">

        <!-- Row 1: Name + Email -->
        <div class="contact-row">
          <div class="contact-field">
            <label class="contact-field-label" for="input-name">Name</label>
            <input type="text" name="name" value="{{ name }}" id="input-name"
                   class="contact-input" placeholder="Full name" autocomplete="name">
            {% if error_name %}<span class="contact-error">{{ error_name }}</span>{% endif %}
          </div>
          <div class="contact-field">
            <label class="contact-field-label" for="input-email">Email</label>
            <input type="email" name="email" value="{{ email }}" id="input-email"
                   class="contact-input" placeholder="you@example.com" autocomplete="email">
            {% if error_email %}<span class="contact-error">{{ error_email }}</span>{% endif %}
          </div>
        </div>

        <!-- Row 2: Subject -->
        <div class="contact-field">
          <label class="contact-field-label" for="input-subject">Subject</label>
          <input type="text" name="subject" value="{{ subject }}" id="input-subject"
                 class="contact-input" placeholder="What's this about?">
        </div>

        <!-- Row 3: Message / Enquiry -->
        <div class="contact-field">
          <label class="contact-field-label" for="input-enquiry">Message</label>
          <textarea name="enquiry" id="input-enquiry"
                    class="contact-input contact-textarea"
                    placeholder="Tell us what you need.">{{ enquiry }}</textarea>
          {% if error_enquiry %}<span class="contact-error">{{ error_enquiry }}</span>{% endif %}
        </div>

        <!-- CAPTCHA -->
        <div class="contact-field">
          {{ captcha }}
        </div>

        <!-- Submit -->
        <button type="submit" class="contact-btn-submit">
          Send Message <i class="fa-solid fa-arrow-right"></i>
        </button>

        <p class="contact-form-foot">We'll get back to you within 24 hours.</p>

      </form>
    </div>

  </div>

</div>

{{ footer }}
