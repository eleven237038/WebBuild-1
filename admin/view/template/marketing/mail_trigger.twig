{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="button" data-toggle="tooltip" title="{{ button_add }}" class="btn btn-primary" onclick="openForm(0);"><i class="fa fa-plus"></i></button>
        <button type="button" data-toggle="tooltip" title="{{ button_delete }}" class="btn btn-danger" onclick="confirm('{{ text_confirm }}') ? $('#form-list').submit() : false;"><i class="fa fa-trash-o"></i></button>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if error_permission %}
    <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_permission }} <button type="button" class="close" data-dismiss="alert">&times;</button></div>
    {% endif %}
    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-list"></i> {{ text_list }}</h3>
      </div>
      <div class="panel-body">
        <form action="{{ delete }}" method="post" enctype="multipart/form-data" id="form-list">
          <div class="table-responsive">
            <table class="table table-bordered table-hover">
              <thead>
                <tr>
                  <td style="width: 1px;" class="text-center"><input type="checkbox" onclick="$('input[name*=\'selected\']').prop(\'checked\', this.checked);" /></td>
                  <td class="text-left">{{ column_code }}</td>
                  <td class="text-left">{{ column_event }}</td>
                  <td class="text-left">{{ column_subject }}</td>
                  <td class="text-left">{{ column_status }}</td>
                  <td class="text-left">{{ column_date_added }}</td>
                  <td class="text-right">{{ column_action }}</td>
                </tr>
              </thead>
              <tbody>
                {% if triggers %}
                {% for t in triggers %}
                <tr>
                  <td class="text-center"><input type="checkbox" name="selected[]" value="{{ t.trigger_id }}" /></td>
                  <td class="text-left">{{ t.code }}</td>
                  <td class="text-left">{{ t.event }}</td>
                  <td class="text-left">{{ t.subject }}</td>
                  <td class="text-left">
                    {% if t.status %}
                    <span class="label label-success">{{ text_enabled }}</span>
                    {% else %}
                    <span class="label label-default">{{ text_disabled }}</span>
                    {% endif %}
                  </td>
                  <td class="text-left">{{ t.date_added }}</td>
                  <td class="text-right">
                    <a onclick="openForm({{ t.trigger_id }});" data-toggle="tooltip" title="{{ button_edit }}" class="btn btn-primary"><i class="fa fa-pencil"></i></a>
                    {% if t.status %}
                    <a onclick="toggleStatus('{{ disable }}&trigger_id={{ t.trigger_id }}');" data-toggle="tooltip" title="{{ button_disable }}" class="btn btn-warning"><i class="fa fa-minus-circle"></i></a>
                    {% else %}
                    <a onclick="toggleStatus('{{ enable }}&trigger_id={{ t.trigger_id }}');" data-toggle="tooltip" title="{{ button_enable }}" class="btn btn-success"><i class="fa fa-plus-circle"></i></a>
                    {% endif %}
                    <a onclick="deleteOne({{ t.trigger_id }});" data-toggle="tooltip" title="{{ button_delete }}" class="btn btn-danger"><i class="fa fa-trash-o"></i></a>
                  </td>
                </tr>
                {% endfor %}
                {% else %}
                <tr>
                  <td class="text-center" colspan="7">{{ text_no_results }}</td>
                </tr>
                {% endif %}
              </tbody>
            </table>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<!-- Form Modal -->
<div class="modal fade" id="form-modal" tabindex="-1" role="dialog">
  <div class="modal-dialog modal-lg" role="document">
    <div class="modal-content">
      <form id="trigger-form">
        <input type="hidden" name="trigger_id" value="0" />
        <input type="hidden" name="message" id="trigger-message-hidden" value="" />
        <div class="modal-header">
          <button type="button" class="close" data-dismiss="modal">&times;</button>
          <h4 class="modal-title">{{ heading_title }}</h4>
        </div>
        <div class="modal-body">
          <div class="form-group required">
            <label class="control-label" for="input-event">{{ entry_event }}</label>
            <select name="event" id="input-event" class="form-control">
              {% for key, label in events %}
              <option value="{{ key }}">{{ label }}</option>
              {% endfor %}
            </select>
          </div>
          <div class="form-group">
            <label class="control-label" for="input-code"><span data-toggle="tooltip" title="{{ help_code }}">{{ entry_code }}</span></label>
            <input type="text" name="code" id="input-code" class="form-control" placeholder="welcome_email" />
          </div>
          <div class="form-group required">
            <label class="control-label" for="input-subject">{{ entry_subject }}</label>
            <input type="text" name="subject" id="input-subject" class="form-control" />
          </div>
          <div class="form-group required">
            <label class="control-label" for="input-message"><span data-toggle="tooltip" title="{{ help_message }}">{{ entry_message }}</span></label>
            <textarea name="message_html" id="input-message" data-toggle="summernote" data-lang="{{ summernote }}" class="form-control"></textarea>
          </div>
          <div class="form-group">
            <label class="control-label">{{ entry_status }}</label>
            <div class="checkbox">
              <label><input type="checkbox" name="status" value="1" checked /> {{ text_enabled }}</label>
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-default" data-dismiss="modal">{{ button_cancel }}</button>
          <button type="button" id="button-save" class="btn btn-primary" data-loading-text="{{ text_loading }}">{{ button_save }}</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script type="text/javascript"><!--
function openForm(trigger_id) {
	$('#trigger-form')[0].reset();
	$('input[name=\'trigger_id\']').val(trigger_id || 0);
	$('input[name=\'status\']').prop('checked', true);
	$('#input-message').summernote('code', '');
	if (trigger_id > 0) {
		$.ajax({
			url: '{{ get }}&trigger_id=' + trigger_id,
			dataType: 'json',
			success: function(json) {
				if (json && json.trigger_id) {
					$('select[name=\'event\']').val(json.event);
					$('input[name=\'code\']').val(json.code);
					$('input[name=\'subject\']').val(json.subject);
					$('#input-message').summernote('code', json.message);
					$('input[name=\'status\']').prop('checked', json.status == 1);
				}
			}
		});
	}
	$('#form-modal').modal('show');
}

$('#button-save').on('click', function() {
	$('input[name=\'message\']').val($('#input-message').summernote('code'));
	$.ajax({
		url: '{{ save }}',
		type: 'post',
		data: $('#trigger-form input, #trigger-form select, #trigger-form textarea'),
		dataType: 'json',
		beforeSend: function() { $('#button-save').button('loading'); },
		complete: function() { $('#button-save').button('reset'); },
		success: function(json) {
			$('.alert-dismissible').remove();
			if (json['error']) {
				$('#form-modal .modal-body').prepend('<div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> ' + json['error'] + ' <button type="button" class="close" data-dismiss="alert">&times;</button></div>');
			}
			if (json['success']) {
				$('#form-modal').modal('hide');
				location.reload();
			}
		},
		error: function(xhr, ajaxOptions, thrownError) {
			alert(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
		}
	});
});

function deleteOne(trigger_id) {
	if (!confirm('{{ text_confirm }}')) return;
	$.ajax({
		url: '{{ delete }}&trigger_id=' + trigger_id,
		type: 'post',
		dataType: 'json',
		success: function(json) { location.reload(); }
	});
}

function toggleStatus(url) {
	$.ajax({
		url: url,
		type: 'post',
		dataType: 'json',
		success: function(json) { location.reload(); }
	});
}

$('#form-list').on('submit', function(e) {
	e.preventDefault();
	if (!$('input[name^="selected"]:checked').length) { return; }
	$.ajax({
		url: '{{ delete }}',
		type: 'post',
		data: $('input[name^="selected"]'),
		dataType: 'json',
		success: function(json) { location.reload(); }
	});
});

$('#input-message').summernote({ height: 220 });
//--></script>
{{ footer }}
