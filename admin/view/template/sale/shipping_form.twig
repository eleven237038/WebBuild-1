{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="submit" form="form-shipping" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa fa-save"></i> {{ button_save }}</button>
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i> {{ button_cancel }}</a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if error_warning %}
    <div class="alert alert-danger"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}<button type="button" class="close" data-dismiss="alert">&times;</button></div>
    {% endif %}
    {% if success %}
    <div class="alert alert-success"><i class="fa fa-check-circle"></i> {{ success }}<button type="button" class="close" data-dismiss="alert">&times;</button></div>
    {% endif %}
    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-truck"></i> {{ text_form }}</h3>
      </div>
      <div class="panel-body">
        <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-shipping" class="form-horizontal">

          <legend>{{ text_section_toggle }}</legend>
          <div class="form-group">
            <label class="col-sm-2 control-label">{{ entry_shipping_enabled }}</label>
            <div class="col-sm-10"><label class="checkbox-inline"><input type="checkbox" name="shipping_enabled" value="1" {{ shipping_enabled == 1 or shipping_enabled == '1' ? 'checked' }}/> {{ entry_shipping_enabled }}</label></div>
          </div>

          <legend>{{ text_section_fee }}</legend>
          <div class="form-group">
            <label class="col-sm-2 control-label">{{ entry_shipping_flat_rate }}</label>
            <div class="col-sm-10"><input type="text" name="shipping_flat_rate" value="{{ shipping_flat_rate }}" class="form-control" style="max-width:240px;" /></div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label">{{ entry_shipping_per_item }}</label>
            <div class="col-sm-10"><input type="text" name="shipping_per_item" value="{{ shipping_per_item }}" class="form-control" style="max-width:240px;" /></div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label">{{ entry_shipping_free_threshold }}</label>
            <div class="col-sm-10"><input type="text" name="shipping_free_threshold" value="{{ shipping_free_threshold }}" class="form-control" style="max-width:240px;" /></div>
          </div>

          {# ===== 运费阶梯 repeater (table-rate; 动态增删, 存为 JSON 数组) ===== #}
          <legend>{{ text_section_tier }}</legend>
          <div class="form-group">
            <label class="col-sm-2 control-label">{{ entry_shipping_tiers }}</label>
            <div class="col-sm-10">
              <div id="tiers-repeater" class="ship-repeater">
                {% for t in shipping_tiers %}
                <div class="ship-rep-row" style="display:flex;gap:10px;margin-bottom:8px;align-items:center;flex-wrap:wrap;">
                  <label style="display:flex;align-items:center;gap:4px;font-weight:normal;margin:0;"><span style="font-size:12px;color:#888;white-space:nowrap;">{{ text_tier_threshold }}</span><input type="text" name="shipping_tiers[{{ loop.index0 }}][threshold]" data-name="shipping_tiers[{i}][threshold]" value="{{ t.threshold }}" class="form-control ship-tier-threshold" style="width:110px;"></label>
                  <label style="display:flex;align-items:center;gap:4px;font-weight:normal;margin:0;"><span style="font-size:12px;color:#888;white-space:nowrap;">{{ text_tier_rate }}</span><input type="text" name="shipping_tiers[{{ loop.index0 }}][rate]" data-name="shipping_tiers[{i}][rate]" value="{{ t.rate }}" class="form-control ship-tier-rate" style="width:110px;"></label>
                  <label style="display:flex;align-items:center;gap:4px;font-weight:normal;margin:0;"><span style="font-size:12px;color:#888;white-space:nowrap;">{{ text_tier_label }}</span><input type="text" name="shipping_tiers[{{ loop.index0 }}][label]" data-name="shipping_tiers[{i}][label]" value="{{ t.label }}" class="form-control ship-tier-label" style="width:180px;"></label>
                  <button type="button" class="btn btn-danger btn-sm ship-rep-remove">{{ button_remove }}</button>
                </div>
                {% endfor %}
              </div>
              <template id="tier-row-tpl">
                <div class="ship-rep-row" style="display:flex;gap:10px;margin-bottom:8px;align-items:center;flex-wrap:wrap;">
                  <label style="display:flex;align-items:center;gap:4px;font-weight:normal;margin:0;"><span style="font-size:12px;color:#888;white-space:nowrap;">{{ text_tier_threshold }}</span><input type="text" name="shipping_tiers[{i}][threshold]" data-name="shipping_tiers[{i}][threshold]" value="" class="form-control ship-tier-threshold" style="width:110px;"></label>
                  <label style="display:flex;align-items:center;gap:4px;font-weight:normal;margin:0;"><span style="font-size:12px;color:#888;white-space:nowrap;">{{ text_tier_rate }}</span><input type="text" name="shipping_tiers[{i}][rate]" data-name="shipping_tiers[{i}][rate]" value="" class="form-control ship-tier-rate" style="width:110px;"></label>
                  <label style="display:flex;align-items:center;gap:4px;font-weight:normal;margin:0;"><span style="font-size:12px;color:#888;white-space:nowrap;">{{ text_tier_label }}</span><input type="text" name="shipping_tiers[{i}][label]" data-name="shipping_tiers[{i}][label]" value="" class="form-control ship-tier-label" style="width:180px;"></label>
                  <button type="button" class="btn btn-danger btn-sm ship-rep-remove">{{ button_remove }}</button>
                </div>
              </template>
              <button type="button" class="btn btn-default btn-sm ship-rep-add" data-target="tiers-repeater" data-tpl="tier-row-tpl">{{ button_add_tier }}</button>
              <p style="font-size:12px;color:#888;margin-top:6px;">{{ text_tier_hint }}</p>
            </div>
          </div>

          <legend>{{ text_section_text }}</legend>
          <div class="form-group">
            <label class="col-sm-2 control-label">{{ entry_shipping_delivery_text }}</label>
            <div class="col-sm-10"><input type="text" name="shipping_delivery_text" value="{{ shipping_delivery_text }}" class="form-control" style="max-width:420px;" /></div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label">{{ entry_shipping_free_hint }}</label>
            <div class="col-sm-10"><input type="text" name="shipping_free_hint" value="{{ shipping_free_hint }}" class="form-control" style="max-width:420px;" /></div>
          </div>

        </form>
      </div>
    </div>
  </div>
</div>
<script>
(function () {
  var form = document.getElementById('form-shipping');
  if (!form) return;

  // reindex 把 data-name 里的 {i} 替换为行序号, 保证提交为 0..N 干净数组
  function reindexRepeater(repeater) {
    repeater.querySelectorAll('.ship-rep-row').forEach(function (row, i) {
      row.querySelectorAll('[data-name]').forEach(function (el) {
        el.name = el.getAttribute('data-name').replace('{i}', i);
      });
    });
  }
  document.querySelectorAll('.ship-rep-add').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var repeater = document.getElementById(btn.getAttribute('data-target'));
      var tpl = document.getElementById(btn.getAttribute('data-tpl'));
      if (!repeater || !tpl) return;
      repeater.appendChild(tpl.content.cloneNode(true));
      reindexRepeater(repeater);
    });
  });
  // 删除行 (委托; 保留 >=1 行以便始终可编辑)
  form.addEventListener('click', function (e) {
    if (!e.target.closest('.ship-rep-remove')) return;
    var repeater = e.target.closest('.ship-repeater');
    var row = e.target.closest('.ship-rep-row');
    if (repeater && row && repeater.querySelectorAll('.ship-rep-row').length > 1) {
      row.remove();
      reindexRepeater(repeater);
    }
  });
  document.querySelectorAll('.ship-repeater').forEach(reindexRepeater);
})();
</script>
{{ footer }}
