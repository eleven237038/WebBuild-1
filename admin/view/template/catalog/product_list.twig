{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="button" data-toggle="tooltip" title="{{ button_filter }}" onclick="$('#filter-product').toggleClass('hidden-sm hidden-xs');" class="btn btn-default hidden-md hidden-lg"><i class="fa fa-filter"></i></button>
        <a href="{{ add }}" data-toggle="tooltip" title="{{ button_add }}" class="btn btn-primary mfo-add-product"><i class="fa fa-plus"></i></a>
        <button type="submit" form="form-product" formaction="{{ copy }}" data-toggle="tooltip" title="{{ button_copy }}" class="btn btn-default"><i class="fa fa-copy"></i></button>
        <button type="button" form="form-product" formaction="{{ delete }}" data-toggle="tooltip" title="{{ button_delete }}" class="btn btn-danger" onclick="confirm('{{ text_confirm }}') ? $('#form-product').submit() : false;"><i class="fa fa-trash-o"></i></button>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">{% if error_warning %}
      <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
        <button type="button" class="close" data-dismiss="alert">&times;</button>
      </div>
    {% endif %}
    {% if success %}
      <div class="alert alert-success alert-dismissible"><i class="fa fa-check-circle"></i> {{ success }}
        <button type="button" class="close" data-dismiss="alert">&times;</button>
      </div>
    {% endif %}
    <style>
      .product-type-panel .type-chips .btn .badge { margin-left:4px; }
      .product-type-panel .type-chips .btn-primary .badge { background-color:#fff; color:#0ea5e9; }
      .product-type-panel .type-chips::-webkit-scrollbar { height:6px; }
      .product-type-panel .type-chips::-webkit-scrollbar-thumb { background:#cbd5e1; border-radius:3px; }
    </style>
    <div class="panel panel-default product-type-panel" style="margin-bottom:12px;">
      <div class="panel-body" style="padding:8px 12px;">
        <div style="display:flex;align-items:center;gap:10px;">
          <span style="color:#64748b;font-weight:600;white-space:nowrap;">商品类型</span>
          <div class="type-chips" style="display:flex;gap:8px;overflow-x:auto;padding:2px 0;white-space:nowrap;flex:1;">
            <a href="{{ product_type_all_url }}" class="btn btn-{{ not filter_product_type ? 'primary' : 'default' }} btn-sm" style="white-space:nowrap;">全部 <span class="badge">{{ product_type_total }}</span></a>
            {% for pt in product_types %}
              <a href="{{ pt.url }}" class="btn btn-{{ filter_product_type == pt.product_type_id ? 'primary' : 'default' }} btn-sm" style="white-space:nowrap;">{{ pt.name }} <span class="badge">{{ pt.count }}</span></a>
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
    <div class="row">
      <div id="filter-product" class="col-sm-12 hidden-sm hidden-xs">
        <div class="panel panel-default">
          <div class="panel-heading">
            <h3 class="panel-title"><i class="fa fa-filter"></i> {{ text_filter }}</h3>
          </div>
          <div class="panel-body">
            <div class="row">
              <div class="col-sm-12">
                <div class="form-group">
                  <div style="margin-bottom:6px;">
                    <input id="cf-add-input" type="text" class="form-control" placeholder="+ 添加筛选字段…" autocomplete="off" style="display:inline-block;width:280px;" />
                    <button type="button" id="button-filter" class="btn btn-primary"><i class="fa fa-filter"></i> {{ button_filter }}</button>
                  </div>
                  <div id="cf-filter-rows">
                    {% for cf in filter_cf %}
                      <div class="cf-row form-inline" style="margin-bottom:6px;" data-tid="{{ cf.tag_id }}">
                        <label class="cf-label" style="min-width:150px;">{{ cf.label }}</label>
                        <select name="filter_cf[{{ cf.tag_id }}]" class="form-control cf-val" style="width:260px;">
                          <option value="">-- 全部 --</option>
                          {% for opt in cf.options %}
                            <option value="{{ opt.value }}" {% if cf.value == opt.value %}selected="selected"{% endif %}>{{ opt.text }}</option>
                          {% endfor %}
                        </select>
                        <button type="button" class="btn btn-danger btn-xs cf-remove" data-tid="{{ cf.tag_id }}" title="移除"><i class="fa fa-times"></i></button>
                      </div>
                    {% endfor %}
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="col-sm-12">
        <div class="panel panel-default">
          <div class="panel-heading">
            <h3 class="panel-title"><i class="fa fa-list"></i> {{ text_list }}</h3>
          </div>
          <div class="panel-body">
            <form action="{{ delete }}" method="post" enctype="multipart/form-data" id="form-product">
              <div class="table-responsive">
                <table class="table table-bordered table-hover">
                  <thead>
                    <tr>
                      <td style="width: 1px;" class="text-center"><input type="checkbox" onclick="$('input[name*=\'selected\']').trigger('click');"/></td>
                      <td class="text-center">{% if sort == 'p.product_id' %}<a href="{{ sort_id }}" class="{{ order|lower }}">{{ column_id }}</a>{% else %}<a href="{{ sort_id }}">{{ column_id }}</a> {% endif %}</td>
                      <td class="text-center">{{ column_image }}</td>
                      <td class="text-center">{% if sort == 'pd.name' %}<a href="{{ sort_name }}" class="{{ order|lower }}">{{ column_name }}</a>{% else %}<a href="{{ sort_name }}">{{ column_name }}</a> {% endif %}</td>
                      <td class="text-center">{% if sort == 'p.model' %}<a href="{{ sort_model }}" class="{{ order|lower }}">{{ column_model }}</a>{% else %}<a href="{{ sort_model }}">{{ column_model }}</a> {% endif %}</td>
                      <td class="text-center">{% if sort == 'p.price' %}<a href="{{ sort_price }}" class="{{ order|lower }}">{{ column_price }}</a>{% else %}<a href="{{ sort_price }}">{{ column_price }}</a> {% endif %}</td>
                      <td class="text-center">{% if sort == 'p.quantity' %}<a href="{{ sort_quantity }}" class="{{ order|lower }}">{{ column_quantity }}</a>{% else %}<a href="{{ sort_quantity }}">{{ column_quantity }}</a> {% endif %}</td>
                      <td class="text-center">{% if sort == 'p.status' %}<a href="{{ sort_status }}" class="{{ order|lower }}">{{ column_status }}</a>{% else %}<a href="{{ sort_status }}">{{ column_status }}</a> {% endif %}</td>
                      {% for col in list_columns %}
                        <td class="text-center">{{ col.name }}</td>
                      {% endfor %}
                      <td class="text-center">{{ column_action }}</td>
                    </tr>
                  </thead>
                  <tbody>
                    {% if products %}
                      {% for product in products %}
                        <tr>
                          <td class="text-center">{% if product.product_id in selected %}
                              <input type="checkbox" name="selected[]" value="{{ product.product_id }}" checked="checked"/>
                            {% else %}
                              <input type="checkbox" name="selected[]" value="{{ product.product_id }}"/>
                            {% endif %}</td>
                          <td class="text-center">
                            <span>{{ product.product_id }}</span>
                          </td>
                          <td class="text-center">{% if product.image %}<img src="{{ product.image }}" alt="{{ product.name }}" class="img-thumbnail"/>{% else %}<span class="img-thumbnail list"><i class="fa fa-camera fa-2x"></i></span>{% endif %}</td>
                          <td class="text-center">{{ product.name }}</td>
                          <td class="text-center">{{ product.model }}</td>
                          <td class="text-center">{% if product.special %}<span style="text-decoration: line-through;">{{ product.price }}</span>
                              <br/>
                              <div class="text-danger">{{ product.special }}</div>
                            {% else %}
                              {{ product.price }}
                            {% endif %}</td>
                          <td class="text-center">{% if product.quantity <= 0 %}<span class="label label-warning">{{ product.quantity }}</span>{% elseif product.quantity <= 5 %}<span class="label label-danger">{{ product.quantity }}</span>{% else %}<span class="label label-success">{{ product.quantity }}</span>{% endif %}</td>
                          <td class="text-center">
                            <input type="checkbox" name="product-status-toggle" data-id="{{ product.product_id }}" {{ product.status ? 'checked' : '' }}>
                          </td>
                          {% for col in list_columns %}
                            <td class="text-center">{{ product.cf_cols[col.tag_id]|default('') }}</td>
                          {% endfor %}
                          <td class="text-center"><a href="{{ product.edit }}" data-toggle="tooltip" title="{{ button_edit }}" class="btn btn-primary"><i class="fa fa-pencil"></i></a> <a href="{{ product.view }}" target="_blank" data-toggle="tooltip" title="{{ button_view }}" class="btn btn-default"><i class="fa fa-search"></i></a></td>
                        </tr>
                      {% endfor %}
                    {% else %}
                      <tr>
                        <td class="text-center" colspan="{{ (list_columns|length) + 9 }}">{{ text_no_results }}</td>
                      </tr>
                    {% endif %}
                  </tbody>
                </table>
              </div>
            </form>
            <div class="row">
              <div class="col-sm-6 text-left">{{ pagination }}</div>
              <div class="col-sm-6 text-right">{{ results }}</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<script type="text/javascript"><!--
$('#button-filter').on('click', function() {
	var url = '';

	// 字段筛选行
	$('#cf-filter-rows .cf-row').each(function() {
		var tid = $(this).data('tid');
		var v = $(this).find('.cf-val').val();
		if (tid && v) {
			url += '&filter_cf[' + tid + ']=' + encodeURIComponent(v);
		}
	});
	url += '&cf_apply=1';

	location = 'index.php?route=catalog/product&user_token={{ user_token }}' + url;
});
//--></script>
<script type="text/javascript"><!--
// 字段筛选: 打字搜索添加 + 移除行, AJAX 取值
window.cfTags = {{ cf_tags|json_encode|raw }};
$('#cf-add-input').autocomplete({
    minLength: 0,
    source: function(request, response) {
        var term = request.term.toLowerCase();
        var list = $.map(window.cfTags, function(t) {
            return { label: t.label, value: t.label, tag_id: t.tag_id };
        });
        list = $.grep(list, function(t) {
            return t.label.toLowerCase().indexOf(term) > -1;
        });
        response(list);
    },
    select: function(event, ui) {
        var tid = ui.item.tag_id;
        var label = ui.item.label;
        $(this).val('');
        if (!tid || $('#cf-filter-rows .cf-row[data-tid="' + tid + '"]').length) {
            return false;
        }
        $.ajax({
            url: 'index.php?route=catalog/product/cfValues&user_token={{ user_token }}&tag_id=' + tid,
            dataType: 'json',
            success: function(opts) {
                var html = '<div class="cf-row form-inline" style="margin-bottom:6px;" data-tid="' + tid + '">' +
                    '<label class="cf-label" style="min-width:150px;">' + $('<div>').text(label).html() + '</label> ' +
                    '<select name="filter_cf[' + tid + ']" class="form-control cf-val" style="width:260px;"><option value="">-- 全部 --</option>';
                $.each(opts, function(i, o) {
                    html += '<option value="' + $('<div>').text(o.value).html() + '">' + $('<div>').text(o.text).html() + '</option>';
                });
                html += '</select> ' +
                    '<button type="button" class="btn btn-danger btn-xs cf-remove" data-tid="' + tid + '" title="移除"><i class="fa fa-times"></i></button>' +
                    '</div>';
                $('#cf-filter-rows').append(html);
            },
            error: function() {
                alert('取值失败,请重试');
            }
        });
        return false;
    }
}).focus(function() {
    $(this).autocomplete('search', '');
});

$(document).on('click', '.cf-remove', function() {
    var row = $(this).closest('.cf-row');
    var hadVal = row.find('.cf-val').val();
    row.remove();
    // 移除的是带值筛选条件 -> 条件改变, 立即刷新列表 (空值字段移除不触发, 避免无谓刷新)
    if (hadVal) {
        $('#button-filter').trigger('click');
    }
});

// 已添加的筛选字段更改值时自动刷新一次列表(委托绑定,覆盖 AJAX 后续添加的行)
$(document).on('change', '.cf-val', function() {
    $('#button-filter').trigger('click');
});
//--></script>
<script type="text/javascript"><!--
// IE and Edge fix!
$('button[form=\'form-product\']').on('click', function(e) {
	$('#form-product').attr('action', $(this).attr('formaction'));
});

$("[name='product-status-toggle']").bootstrapSwitch({
  onText: '{{ text_enabled }}',
  offText: '{{ text_disabled }}',
  labelText: '{{ entry_status }}',
  size: 'mini',
});

$('input[name="product-status-toggle"]').on('switchChange.bootstrapSwitch', function(event, state) {
  var switcher = $(this);
  $.ajax({
    url: 'index.php?route=catalog/product/status&user_token={{ user_token }}&product_id=' + $(this).data('id') + '&status=' + (state ? 1 : 0),
    dataType: 'json',
    beforeSend: function () {
      switcher.bootstrapSwitch('toggleReadonly', true);
    },
    success: function (json) {
      switcher.bootstrapSwitch('toggleReadonly', false);
      if (json['status'] !== 1) {
        switcher.bootstrapSwitch('state', !state, true);
      }
    },
    error: function () {
      switcher.bootstrapSwitch('toggleReadonly', false);
      switcher.bootstrapSwitch('state', !state, true);
    }
  });
});
//--></script>
<script type="text/javascript"><!--
$(function() {
  // ── 新建商品 走模态弹窗 (不再跳整页) ──
  $(document).on('click', '.mfo-add-product', function(e) { e.preventDefault(); openModalForm(this.href, '新建商品'); });
});
//--></script>
{% include 'common/modal_form_overlay.twig' %}
{{ footer }}
