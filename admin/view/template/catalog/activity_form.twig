{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="submit" form="form-activity" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa fa-save"></i> {{ button_save }}</button>
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i> {{ button_cancel }}</a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if error_warning %}
    <div class="alert alert-danger"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}<button type="button" class="close" data-dismiss="alert">&times;</button></div>
    {% endif %}
    {% if success %}
    <div class="alert alert-success"><i class="fa fa-check-circle"></i> {{ success }}<button type="button" class="close" data-dismiss="alert">&times;</button></div>
    {% endif %}

    {# ---- Live preview (mirrors the homepage activity block) ---- #}
    <div class="panel panel-default">
      <div class="panel-heading"><h3 class="panel-title"><i class="fa fa-eye"></i> 实时预览</h3></div>
      <div class="panel-body" style="padding:0;">
        <div id="activity-preview" style="display:flex;align-items:center;justify-content:space-between;gap:24px;padding:32px 36px;background:{{ activity_bg_color }};color:{{ activity_text_color }};border-radius:0;">
          <div style="flex:1 1 auto;">
            {% if activity_tag %}<div class="ap-tag" style="font-size:12px;letter-spacing:.18em;text-transform:uppercase;font-weight:700;color:{{ activity_accent_color }};margin-bottom:8px;">{{ activity_tag }}</div>{% endif %}
            <div class="ap-title" style="font-size:28px;font-weight:800;line-height:1.15;margin-bottom:8px;">{{ activity_title }}</div>
            {% if activity_subtitle %}<div class="ap-sub" style="font-size:14px;opacity:.85;max-width:560px;line-height:1.5;">{{ activity_subtitle }}</div>{% endif %}
            {% if activity_cta_label %}<span class="ap-cta" style="display:inline-block;margin-top:16px;padding:10px 22px;border-radius:999px;font-weight:700;font-size:14px;background:{{ activity_accent_color }};color:#0F172A;">{{ activity_cta_label }}</span>{% endif %}
          </div>
          {% if activity_badge %}<div class="ap-badge" style="flex:0 0 auto;font-size:44px;font-weight:900;line-height:1;color:{{ activity_accent_color }};">{{ activity_badge }}</div>{% endif %}
        </div>
      </div>
    </div>

    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-bullhorn"></i> {{ text_form }}</h3>
      </div>
      <div class="panel-body">
        <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-activity" class="form-horizontal">

          <legend>开关</legend>
          <div class="form-group">
            <label class="col-sm-2 control-label">{{ entry_status }}</label>
            <div class="col-sm-10"><label class="checkbox-inline"><input type="checkbox" name="activity_enabled" value="1" id="fld-enabled" {{ activity_enabled == 1 or activity_enabled == '1' ? 'checked' }}/> {{ text_enabled }}</label></div>
          </div>

          <legend>文案</legend>
          <div class="form-group">
            <label class="col-sm-2 control-label">{{ entry_tag }}</label>
            <div class="col-sm-10">
              <input type="text" name="activity_tag" id="fld-tag" value="{{ activity_tag }}" class="form-control" style="max-width:420px;" />
              <div class="help-block">{{ help_tag }}</div>
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label">{{ entry_title }}</label>
            <div class="col-sm-10"><input type="text" name="activity_title" id="fld-title" value="{{ activity_title }}" class="form-control" style="max-width:560px;" /></div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label">{{ entry_subtitle }}</label>
            <div class="col-sm-10"><textarea name="activity_subtitle" id="fld-subtitle" rows="2" class="form-control" style="max-width:640px;">{{ activity_subtitle }}</textarea></div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label">{{ entry_badge }}</label>
            <div class="col-sm-10">
              <input type="text" name="activity_badge" id="fld-badge" value="{{ activity_badge }}" class="form-control" style="max-width:200px;" />
              <div class="help-block">{{ help_badge }}</div>
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label">{{ entry_cta_label }}</label>
            <div class="col-sm-10"><input type="text" name="activity_cta_label" id="fld-cta-label" value="{{ activity_cta_label }}" class="form-control" style="max-width:320px;" /></div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label">{{ entry_cta_url }}</label>
            <div class="col-sm-10">
              <input type="text" name="activity_cta_url" id="fld-cta-url" value="{{ activity_cta_url }}" class="form-control" style="max-width:560px;" />
              <div class="help-block">{{ help_cta_url }}</div>
            </div>
          </div>

          <legend>配色</legend>
          <div class="form-group">
            <label class="col-sm-2 control-label">{{ entry_bg_color }}</label>
            <div class="col-sm-10"><input type="color" name="activity_bg_color" id="fld-bg" value="{{ activity_bg_color }}" class="form-control" style="max-width:80px;height:38px;padding:2px;" /></div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label">{{ entry_text_color }}</label>
            <div class="col-sm-10"><input type="color" name="activity_text_color" id="fld-text" value="{{ activity_text_color }}" class="form-control" style="max-width:80px;height:38px;padding:2px;" /></div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label">{{ entry_accent_color }}</label>
            <div class="col-sm-10"><input type="color" name="activity_accent_color" id="fld-accent" value="{{ activity_accent_color }}" class="form-control" style="max-width:80px;height:38px;padding:2px;" /></div>
          </div>

        </form>
      </div>
    </div>
  </div>
</div>
<script>
// Live preview: every field updates the preview block above as you type.
(function(){
  var box = document.getElementById('activity-preview');
  if (!box) return;
  function val(id){ var el = document.getElementById(id); return el ? el.value : ''; }
  function escapeHtml(s){ return String(s).replace(/[&<>"']/g, function(c){ return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]; }); }
  function render(){
    var bg = val('fld-bg'), txt = val('fld-text'), acc = val('fld-accent');
    var tag = val('fld-tag'), title = val('fld-title'), sub = val('fld-subtitle');
    var badge = val('fld-badge'), ctaLabel = val('fld-cta-label'), ctaUrl = val('fld-cta-url');
    box.style.background = bg;
    box.style.color = txt;
    var html = '<div style="flex:1 1 auto;">';
    if (tag) html += '<div style="font-size:12px;letter-spacing:.18em;text-transform:uppercase;font-weight:700;color:'+acc+';margin-bottom:8px;">'+escapeHtml(tag)+'</div>';
    html += '<div style="font-size:28px;font-weight:800;line-height:1.15;margin-bottom:8px;">'+escapeHtml(title || '')+'</div>';
    if (sub) html += '<div style="font-size:14px;opacity:.85;max-width:560px;line-height:1.5;">'+escapeHtml(sub)+'</div>';
    if (ctaLabel) html += '<span style="display:inline-block;margin-top:16px;padding:10px 22px;border-radius:999px;font-weight:700;font-size:14px;background:'+acc+';color:#0F172A;">'+escapeHtml(ctaLabel)+'</span>';
    html += '</div>';
    if (badge) html += '<div style="flex:0 0 auto;font-size:44px;font-weight:900;line-height:1;color:'+acc+';">'+escapeHtml(badge)+'</div>';
    box.innerHTML = html;
  }
  ['fld-tag','fld-title','fld-subtitle','fld-badge','fld-cta-label','fld-bg','fld-text','fld-accent'].forEach(function(id){
    var el = document.getElementById(id);
    if (el) el.addEventListener('input', render);
  });
})();
</script>
{{ footer }}
