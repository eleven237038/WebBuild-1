{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="submit" form="form-product-detail" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa fa-save"></i> {{ button_save }}</button>
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i> {{ button_cancel }}</a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if error_warning %}
    <div class="alert alert-danger"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}<button type="button" class="close" data-dismiss="alert">&times;</button></div>
    {% endif %}
    {% if success %}
    <div class="alert alert-success"><i class="fa fa-check-circle"></i> {{ success }}<button type="button" class="close" data-dismiss="alert">&times;</button></div>
    {% endif %}

    {# 商品类型 chip bar: 切换编辑不同商品类型的详情页设置 (type 1 = 全局默认)
       sticky 顶部, 任何窗口大小/模式都始终可见 #}
    <div class="panel panel-default pdp-typebar" style="margin-bottom:12px;">
      <div class="panel-body" style="padding:8px 12px;">
        <div style="display:flex;align-items:center;gap:10px;">
          <span style="color:#64748b;font-weight:600;white-space:nowrap;">商品类型</span>
          <div style="display:flex;gap:8px;overflow-x:auto;padding:2px 0;white-space:nowrap;flex:1;">
            {% for pt in product_types %}
              <a href="{{ pt.url }}" class="btn btn-{{ pt.active ? 'primary' : 'default' }} btn-sm" style="white-space:nowrap;">{{ pt.name }}</a>
            {% endfor %}
          </div>
        </div>
      </div>
    </div>

    {# 复用前台 product-card.css (相关商品卡片) + 共享浮窗样式 #}
    <link rel="stylesheet" href="../catalog/view/theme/default/stylesheet/genscript/product-card.css">
    <link rel="stylesheet" href="view/stylesheet/genscript/preview-float.css?v=20260723b">
    <style>
      {# 商品类型 chip bar: 始终吸顶可见 #}
      .pdp-typebar { position: sticky; top: 0; z-index: 1050; background: #fff; box-shadow: 0 2px 8px rgba(0,0,0,.06); }
      {# 表单占满宽度; 跳转滚动时为吸顶类型栏预留空间 #}
      .pcard-admin-form .form-group { scroll-margin-top: calc(var(--pdp-typebar-h, 52px) + 16px); }
      .pcard-preview-hint { font-size: 12px; color: #888; margin: 0 0 12px; }
      {# 点击预览各部分 -> 跳转并高亮对应编辑项 #}
      #pdp-preview-frame [data-jump] { cursor: pointer; }
      #pdp-preview-frame [data-jump]:hover { outline: 2px dashed var(--pdp-primary, #10B981); outline-offset: 3px; border-radius: 4px; }
      .pcard-jump-flash { border-radius: 4px; animation: pcard-jump-flash 1.4s ease-out; }
      @keyframes pcard-jump-flash {
        0%, 18% { background-color: #fff3cd; box-shadow: 0 0 0 3px rgba(255,193,7,.55); }
        100% { background-color: transparent; box-shadow: 0 0 0 0 transparent; }
      }

      {# ===== PDP 预览画布: 作用域化, 隔离配色变量 (不污染后台 :root) ===== #}
      #pdp-preview-frame {
        --pdp-primary: #10B981;
        --pdp-bg-navy: #0F172A;
        background: #fff;
        padding: 14px;
        border-radius: 10px;
        border: 1px solid #e8e8e8;
        min-height: 120px;
        font-family: "Figtree", -apple-system, "Segoe UI", sans-serif;
      }
      #pdp-preview-frame .pdp-wrap { max-width: 100%; padding: 0; margin: 0; }
      #pdp-preview-frame .pdp-breadcrumb { font-size: 11px; color: #999; padding: 0 0 8px; }
      #pdp-preview-frame .pdp-breadcrumb a { color: var(--pdp-primary); text-decoration: none; }
      #pdp-preview-frame .pdp-buy { display: flex; flex-direction: column; gap: 12px; padding: 0; }
      #pdp-preview-frame .pdp-main-img { position: relative; background: var(--pdp-bg-navy); border-radius: 10px; aspect-ratio: 16 / 9; display: flex; align-items: center; justify-content: center; overflow: hidden; }
      #pdp-preview-frame .pdp-mol { font-size: 44px; line-height: 1; }
      #pdp-preview-frame .pdp-badge { position: absolute; top: 10px; left: 10px; background: var(--pdp-primary); color: #fff; font-size: 10px; font-weight: 700; padding: 4px 10px; border-radius: 4px; letter-spacing: .5px; }
      #pdp-preview-frame .pdp-cat { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px; color: var(--pdp-primary); margin: 0 0 4px; }
      #pdp-preview-frame .pdp-title { font-weight: 900; color: var(--pdp-bg-navy); margin: 0 0 8px; line-height: 1.2; word-break: break-word; }
      #pdp-preview-frame .pdp-tags { display: flex; gap: 6px; margin-bottom: 10px; flex-wrap: wrap; }
      #pdp-preview-frame .pdp-tag { padding: 3px 10px; background: #ecfdf5; color: var(--pdp-primary); font-size: 10px; font-weight: 700; border-radius: 12px; letter-spacing: .3px; }
      #pdp-preview-frame .pdp-desc { color: #555; line-height: 1.55; margin: 0 0 12px; }
      #pdp-preview-frame .pdp-price { font-size: 22px; font-weight: 900; color: var(--pdp-bg-navy); margin: 0 0 10px; }
      #pdp-preview-frame .pdp-qty-row { display: flex; align-items: center; gap: 8px; margin-bottom: 12px; }
      #pdp-preview-frame .pdp-qty { width: 34px; height: 34px; text-align: center; border: 1px solid #e0e0e0; border-radius: 6px; font-size: 13px; font-weight: 700; line-height: 34px; color: #555; }
      #pdp-preview-frame .pdp-add-btn { flex: 1; height: 34px; background: var(--pdp-primary); color: #fff; border: none; border-radius: 6px; font-size: 12px; font-weight: 700; cursor: default; display: flex; align-items: center; justify-content: center; gap: 6px; }
      #pdp-preview-frame .pdp-trust { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 8px; padding: 10px 12px; }
      #pdp-preview-frame .pdp-trust li { list-style: none; padding: 3px 0; font-size: 11px; color: #555; display: flex; align-items: center; gap: 6px; }
      #pdp-preview-frame .pdp-trust li i { color: var(--pdp-primary); font-size: 13px; }
      #pdp-preview-frame .pdp-tabs-section { border-top: 1px solid #e5e7eb; margin-top: 4px; }
      #pdp-preview-frame .pdp-tab-nav { display: flex; border-bottom: 1px solid #e5e7eb; flex-wrap: wrap; }
      #pdp-preview-frame .pdp-tab-link { padding: 8px 12px; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .3px; color: #999; border: none; background: none; border-bottom: 2px solid transparent; margin-bottom: -1px; cursor: pointer; }
      #pdp-preview-frame .pdp-tab-link.active { color: var(--pdp-bg-navy); border-bottom-color: var(--pdp-primary); }
      #pdp-preview-frame .pdp-tab-panel { padding: 10px 0; border-bottom: 1px dashed #eee; }
      #pdp-preview-frame .pdp-tab-panel:last-child { border-bottom: none; }
      #pdp-preview-frame .pdp-tab-panel p { color: #555; line-height: 1.55; margin: 0; white-space: pre-wrap; }
      #pdp-preview-frame .pdp-tab-panel .pdp-panel-label { display: block; font-size: 9px; font-weight: 700; text-transform: uppercase; color: #bbb; letter-spacing: .5px; margin-bottom: 3px; }
      #pdp-preview-frame .pdp-section { padding: 14px 0; border-top: 1px solid #e5e7eb; }
      #pdp-preview-frame .pdp-section-tag { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px; color: var(--pdp-primary); margin: 0 0 4px; }
      #pdp-preview-frame .pdp-section-title { font-weight: 900; font-size: 15px; color: var(--pdp-bg-navy); margin: 0 0 10px; text-transform: uppercase; }
      #pdp-preview-frame .pdp-related-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
      #pdp-preview-frame .pdp-related-card { border: 1px solid #f0f0f0; border-radius: 8px; overflow: hidden; }
      #pdp-preview-frame .pdp-related-card .img-wrap { background: var(--pdp-bg-navy); height: 46px; display: flex; align-items: center; justify-content: center; font-size: 20px; }
      #pdp-preview-frame .pdp-related-card .body { padding: 6px 8px; }
      #pdp-preview-frame .pdp-related-card .body h3 { font-size: 11px; font-weight: 700; color: var(--pdp-bg-navy); margin: 0 0 2px; }
      #pdp-preview-frame .pdp-related-card .body .price { font-size: 12px; font-weight: 800; color: var(--pdp-bg-navy); }
      #pdp-preview-frame .pdp-research-item { display: block; padding: 6px 0; font-size: 11px; font-weight: 700; color: var(--pdp-bg-navy); text-decoration: none; border-bottom: 1px solid #f0f0f0; }
      #pdp-preview-frame .pdp-research-item:last-child { border-bottom: none; }
    </style>

    <div class="pcard-admin-form">
        <div class="panel panel-default">
          <div class="panel-heading">
            <h3 class="panel-title"><i class="fa fa-file-text-o"></i> {{ text_form }}</h3>
          </div>
          <div class="panel-body">
            <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-product-detail" class="form-horizontal">

              <legend>{{ text_section_toggle }}</legend>
              <div class="form-group">
                <label class="col-sm-2 control-label">{{ entry_product_detail_show_breadcrumb }}</label>
                <div class="col-sm-10"><label class="checkbox-inline"><input type="checkbox" name="product_detail_show_breadcrumb" value="1" {{ product_detail_show_breadcrumb == 1 or product_detail_show_breadcrumb == '1' ? 'checked' }}/> {{ entry_product_detail_show_breadcrumb }}</label></div>
              </div>
              <div class="form-group">
                <label class="col-sm-2 control-label">{{ entry_product_detail_show_gallery }}</label>
                <div class="col-sm-10"><label class="checkbox-inline"><input type="checkbox" name="product_detail_show_gallery" value="1" {{ product_detail_show_gallery == 1 or product_detail_show_gallery == '1' ? 'checked' }}/> {{ entry_product_detail_show_gallery }}</label></div>
              </div>
              <div class="form-group">
                <label class="col-sm-2 control-label">{{ entry_product_detail_show_badges }}</label>
                <div class="col-sm-10"><label class="checkbox-inline"><input type="checkbox" name="product_detail_show_badges" value="1" {{ product_detail_show_badges == 1 or product_detail_show_badges == '1' ? 'checked' }}/> {{ entry_product_detail_show_badges }}</label></div>
              </div>
              <div class="form-group">
                <label class="col-sm-2 control-label">{{ entry_product_detail_show_trust_box }}</label>
                <div class="col-sm-10"><label class="checkbox-inline"><input type="checkbox" name="product_detail_show_trust_box" value="1" {{ product_detail_show_trust_box == 1 or product_detail_show_trust_box == '1' ? 'checked' }}/> {{ entry_product_detail_show_trust_box }}</label></div>
              </div>
              <div class="form-group">
                <label class="col-sm-2 control-label">{{ entry_product_detail_show_tabs }}</label>
                <div class="col-sm-10"><label class="checkbox-inline"><input type="checkbox" name="product_detail_show_tabs" value="1" {{ product_detail_show_tabs == 1 or product_detail_show_tabs == '1' ? 'checked' }}/> {{ entry_product_detail_show_tabs }}</label></div>
              </div>
              <div class="form-group">
                <label class="col-sm-2 control-label">{{ entry_product_detail_show_related }}</label>
                <div class="col-sm-10"><label class="checkbox-inline"><input type="checkbox" name="product_detail_show_related" value="1" {{ product_detail_show_related == 1 or product_detail_show_related == '1' ? 'checked' }}/> {{ entry_product_detail_show_related }}</label></div>
              </div>
              <div class="form-group">
                <label class="col-sm-2 control-label">{{ entry_product_detail_show_research }}</label>
                <div class="col-sm-10"><label class="checkbox-inline"><input type="checkbox" name="product_detail_show_research" value="1" {{ product_detail_show_research == 1 or product_detail_show_research == '1' ? 'checked' }}/> {{ entry_product_detail_show_research }}</label></div>
              </div>

              <legend>{{ text_section_size }}</legend>
              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-title-fs">{{ entry_product_detail_title_font_size }}</label>
                <div class="col-sm-10"><input type="number" name="product_detail_title_font_size" value="{{ product_detail_title_font_size }}" id="input-title-fs" class="form-control" style="max-width:200px;"></div>
              </div>
              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-body-fs">{{ entry_product_detail_body_font_size }}</label>
                <div class="col-sm-10"><input type="number" name="product_detail_body_font_size" value="{{ product_detail_body_font_size }}" id="input-body-fs" class="form-control" style="max-width:200px;"></div>
              </div>

              <legend>{{ text_section_text }}</legend>
              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-coa-badge">{{ entry_product_detail_coa_badge_text }}</label>
                <div class="col-sm-10"><input type="text" name="product_detail_coa_badge_text" value="{{ product_detail_coa_badge_text }}" id="input-coa-badge" class="form-control" style="max-width:300px;"></div>
              </div>
              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-batch-verified">{{ entry_product_detail_batch_verified_text }}</label>
                <div class="col-sm-10"><input type="text" name="product_detail_batch_verified_text" value="{{ product_detail_batch_verified_text }}" id="input-batch-verified" class="form-control" style="max-width:300px;"></div>
              </div>
              {# ===== Trust items repeater (was capped at 3) ===== #}
              <div class="form-group">
                <label class="col-sm-2 control-label">{{ entry_product_detail_trust_items }}</label>
                <div class="col-sm-10">
                  <div id="trust-repeater" class="pdp-repeater">
                    {% for ti in product_detail_trust_items %}
                    <div class="pdp-rep-row" style="display:flex;gap:8px;margin-bottom:8px;align-items:center;">
                      <input type="text" name="product_detail_trust_items[]" value="{{ ti }}" class="form-control" style="max-width:380px;" placeholder="保障项文字">
                      <button type="button" class="btn btn-danger btn-sm pdp-rep-remove">{{ button_remove }}</button>
                    </div>
                    {% endfor %}
                  </div>
                  <template id="trust-row-tpl">
                    <div class="pdp-rep-row" style="display:flex;gap:8px;margin-bottom:8px;align-items:center;">
                      <input type="text" name="product_detail_trust_items[]" value="" class="form-control" style="max-width:380px;" placeholder="保障项文字">
                      <button type="button" class="btn btn-danger btn-sm pdp-rep-remove">{{ button_remove }}</button>
                    </div>
                  </template>
                  <button type="button" class="btn btn-default btn-sm pdp-rep-add" data-target="trust-repeater" data-tpl="trust-row-tpl">{{ button_add_trust }}</button>
                </div>
              </div>

              {# ===== Tabs repeater (was 3 fixed: details/coa/shipping) ===== #}
              <div class="form-group">
                <label class="col-sm-2 control-label">{{ entry_product_detail_tabs }}</label>
                <div class="col-sm-10">
                  <div id="tabs-repeater" class="pdp-repeater">
                    {% for tb in product_detail_tabs %}
                    <div class="pdp-rep-row pdp-tab-row" style="border:1px solid #e8e8e8;border-radius:8px;padding:10px;margin-bottom:10px;">
                      <div style="display:flex;gap:8px;margin-bottom:6px;align-items:center;flex-wrap:wrap;">
                        <input type="text" name="product_detail_tabs[{{ loop.index0 }}][label]" data-name="product_detail_tabs[{i}][label]" value="{{ tb.label }}" class="form-control pdp-tab-label" style="max-width:280px;" placeholder="{{ text_tab_label }}">
                        <label class="checkbox-inline" style="white-space:nowrap;"><input type="checkbox" name="product_detail_tabs[{{ loop.index0 }}][is_details]" data-name="product_detail_tabs[{i}][is_details]" value="1" class="pdp-tab-is-details" {{ tb.is_details ? 'checked' }}/> {{ text_tab_is_details }}</label>
                        <button type="button" class="btn btn-danger btn-sm pdp-rep-remove">{{ button_remove }}</button>
                      </div>
                      <textarea name="product_detail_tabs[{{ loop.index0 }}][body]" data-name="product_detail_tabs[{i}][body]" rows="3" class="form-control pdp-tab-body" placeholder="{{ text_tab_body }}">{{ tb.body }}</textarea>
                    </div>
                    {% endfor %}
                  </div>
                  <template id="tab-row-tpl">
                    <div class="pdp-rep-row pdp-tab-row" style="border:1px solid #e8e8e8;border-radius:8px;padding:10px;margin-bottom:10px;">
                      <div style="display:flex;gap:8px;margin-bottom:6px;align-items:center;flex-wrap:wrap;">
                        <input type="text" name="" data-name="product_detail_tabs[{i}][label]" value="" class="form-control pdp-tab-label" style="max-width:280px;" placeholder="{{ text_tab_label }}">
                        <label class="checkbox-inline" style="white-space:nowrap;"><input type="checkbox" name="" data-name="product_detail_tabs[{i}][is_details]" value="1" class="pdp-tab-is-details"> {{ text_tab_is_details }}</label>
                        <button type="button" class="btn btn-danger btn-sm pdp-rep-remove">{{ button_remove }}</button>
                      </div>
                      <textarea name="" data-name="product_detail_tabs[{i}][body]" rows="3" class="form-control pdp-tab-body" placeholder="{{ text_tab_body }}"></textarea>
                    </div>
                  </template>
                  <button type="button" class="btn btn-default btn-sm pdp-rep-add" data-target="tabs-repeater" data-tpl="tab-row-tpl">{{ button_add_tab }}</button>
                  <div class="help-block">{{ help_tab_is_details }}</div>
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-related-title">{{ entry_product_detail_related_title }}</label>
                <div class="col-sm-10"><input type="text" name="product_detail_related_title" value="{{ product_detail_related_title }}" id="input-related-title" class="form-control" style="max-width:300px;"></div>
              </div>
              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-research-title">{{ entry_product_detail_research_title }}</label>
                <div class="col-sm-10"><input type="text" name="product_detail_research_title" value="{{ product_detail_research_title }}" id="input-research-title" class="form-control" style="max-width:300px;"></div>
              </div>

              {# ===== Research links repeater (was capped at 4) ===== #}
              <div class="form-group">
                <label class="col-sm-2 control-label">{{ entry_product_detail_research_links }}</label>
                <div class="col-sm-10">
                  <div id="research-repeater" class="pdp-repeater">
                    {% for rl in product_detail_research_links %}
                    <div class="pdp-rep-row" style="display:flex;gap:8px;margin-bottom:8px;">
                      <input type="text" name="product_detail_research_links[{{ loop.index0 }}][label]" data-name="product_detail_research_links[{i}][label]" value="{{ rl.label }}" class="form-control pdp-rl-label" placeholder="{{ text_rl_label }}">
                      <input type="text" name="product_detail_research_links[{{ loop.index0 }}][url]" data-name="product_detail_research_links[{i}][url]" value="{{ rl.url }}" class="form-control pdp-rl-url" placeholder="{{ text_rl_url }}">
                      <button type="button" class="btn btn-danger btn-sm pdp-rep-remove">{{ button_remove }}</button>
                    </div>
                    {% endfor %}
                  </div>
                  <template id="research-row-tpl">
                    <div class="pdp-rep-row" style="display:flex;gap:8px;margin-bottom:8px;">
                      <input type="text" name="" data-name="product_detail_research_links[{i}][label]" value="" class="form-control pdp-rl-label" placeholder="{{ text_rl_label }}">
                      <input type="text" name="" data-name="product_detail_research_links[{i}][url]" value="" class="form-control pdp-rl-url" placeholder="{{ text_rl_url }}">
                      <button type="button" class="btn btn-danger btn-sm pdp-rep-remove">{{ button_remove }}</button>
                    </div>
                  </template>
                  <button type="button" class="btn btn-default btn-sm pdp-rep-add" data-target="research-repeater" data-tpl="research-row-tpl">{{ button_add_link }}</button>
                </div>
              </div>

              <legend>{{ text_section_color }}</legend>
              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-pdp-primary">{{ entry_product_detail_primary_color }}</label>
                <div class="col-sm-10"><input type="color" name="product_detail_primary_color" value="{{ product_detail_primary_color }}" id="input-pdp-primary" class="form-control" style="max-width:80px;height:38px;padding:2px;"></div>
              </div>
              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-pdp-navy">{{ entry_product_detail_bg_navy }}</label>
                <div class="col-sm-10"><input type="color" name="product_detail_bg_navy" value="{{ product_detail_bg_navy }}" id="input-pdp-navy" class="form-control" style="max-width:80px;height:38px;padding:2px;"></div>
              </div>

            </form>
          </div>
        </div>
      </div>

      {# ===== 实时预览浮窗 (可拖拽/最小化/关闭, 右上角固定; 左边可横向拉伸, 标题右侧一键切换手机/电脑尺寸) ===== #}
      <div id="pf-window" class="pf-window">
        <div class="pf-resize" id="pf-resize" title="横向拉伸"></div>
        <div class="pf-header" id="pf-header">
          <span class="pf-title"><i class="fa fa-eye"></i> {{ text_preview }}</span>
          <span class="pf-devices">
            <button type="button" class="pf-btn pf-device" id="pf-device-phone" title="手机尺寸"><i class="fa fa-mobile"></i></button>
            <button type="button" class="pf-btn pf-device" id="pf-device-desktop" title="电脑尺寸"><i class="fa fa-desktop"></i></button>
          </span>
          <span class="pf-actions">
            <button type="button" class="pf-btn" id="pf-min" title="最小化"><i class="fa fa-minus"></i></button>
            <button type="button" class="pf-btn" id="pf-close" title="关闭"><i class="fa fa-times"></i></button>
          </span>
        </div>
        <div class="pf-body" id="pf-body">
          <p class="pcard-preview-hint">{{ text_preview_hint }}</p>
          <div id="pdp-preview-frame"></div>
        </div>
      </div>
      <button type="button" id="pf-fab" class="pf-fab" title="{{ text_preview }}"><i class="fa fa-eye"></i></button>
  </div>
</div>

<script src="view/javascript/genscript/preview-float.js?v=20260723b"></script>
<script>
(function () {
  // 示例商品数据 (用于预览渲染; 与前台 product.twig 结构保持一致)
  var SAMPLE = {
    title: 'BPC-157 高纯度合成多肽试剂',
    cat: '多肽试剂 / PEPTIDE',
    price: '¥299.00',
    desc: '实验室级高纯度合成多肽试剂，纯度≥99%，适用于细胞培养与体外研究。每瓶5mg装量，-20°C避光保存，长期稳定性经验证。',
    related: [
      { name: 'TB-500 5mg', price: '¥329.00' },
      { name: 'GHK-Cu 10mg', price: '¥259.00' }
    ]
  };

  var form = document.getElementById('form-product-detail');
  var frame = document.getElementById('pdp-preview-frame');
  if (!form || !frame) return;

  function field(name) { return form.querySelector('[name="' + name + '"]'); }
  function chk(name) { var el = field(name); return el && el.checked ? 1 : 0; }
  function num(name, def) { var el = field(name); var v = el ? parseInt(el.value, 10) : NaN; return isNaN(v) ? def : v; }
  function val(name, def) { var el = field(name); return el && el.value !== '' ? el.value : def; }

  function read() {
    // Repeaters: read straight from the DOM (names are array-indexed, so the
    // [name="..."] helper can't match them - query by row class instead).
    var trustItems = [];
    form.querySelectorAll('#trust-repeater .pdp-rep-row input[type="text"]').forEach(function (el) {
      var v = el.value.trim();
      if (v) { trustItems.push(el.value); }
    });
    var tabs = [];
    form.querySelectorAll('#tabs-repeater .pdp-tab-row').forEach(function (row) {
      var label = row.querySelector('.pdp-tab-label').value;
      var body = row.querySelector('.pdp-tab-body').value;
      var isDetails = row.querySelector('.pdp-tab-is-details').checked ? 1 : 0;
      if (label.trim() !== '' || body.trim() !== '') {
        tabs.push({ label: label, body: body, is_details: isDetails });
      }
    });
    var links = [];
    form.querySelectorAll('#research-repeater .pdp-rep-row').forEach(function (row) {
      var label = row.querySelector('.pdp-rl-label').value;
      var url = row.querySelector('.pdp-rl-url').value;
      if (label.trim() !== '' || url.trim() !== '') {
        links.push({ label: label, url: url });
      }
    });
    return {
      show_breadcrumb: chk('product_detail_show_breadcrumb'),
      show_gallery: chk('product_detail_show_gallery'),
      show_badges: chk('product_detail_show_badges'),
      show_trust_box: chk('product_detail_show_trust_box'),
      show_tabs: chk('product_detail_show_tabs'),
      show_related: chk('product_detail_show_related'),
      show_research: chk('product_detail_show_research'),
      title_font_size: num('product_detail_title_font_size', 38),
      body_font_size: num('product_detail_body_font_size', 15),
      coa_badge_text: val('product_detail_coa_badge_text', '★ COA ON FILE'),
      batch_verified_text: val('product_detail_batch_verified_text', 'BATCH-VERIFIED'),
      trust_items: trustItems,
      tabs: tabs,
      related_title: val('product_detail_related_title', 'MORE COMPOUNDS'),
      research_title: val('product_detail_research_title', 'RESEARCH LIBRARY'),
      research_links: links,
      primary_color: val('product_detail_primary_color', '#10B981'),
      bg_navy: val('product_detail_bg_navy', '#0F172A')
    };
  }

  function esc(s) {
    return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  // 构建详情页 HTML - 对应 catalog/.../product/product.twig 的渲染分支
  // 每个可点部分带 data-jump, 点击跳转到对应设置项
  function build(s) {
    var html = '<div class="pdp-wrap">';
    if (s.show_breadcrumb) {
      html += '<p class="pdp-breadcrumb" data-jump="product_detail_show_breadcrumb"><a>HOME</a> / <a>SHOP</a> / <span>' + esc(SAMPLE.title) + '</span></p>';
    }
    html += '<div class="pdp-buy">';
    if (s.show_gallery) {
      html += '<div class="pdp-gallery" data-jump="product_detail_show_gallery">';
      html += '<div class="pdp-main-img">';
      if (s.show_badges) {
        html += '<span class="pdp-badge" data-jump="product_detail_coa_badge_text">' + esc(s.coa_badge_text) + '</span>';
      }
      html += '<span class="pdp-mol">🧪</span>';
      html += '</div>';
      html += '</div>';
    }
    html += '<div class="pdp-info">';
    html += '<p class="pdp-cat">// ' + esc(SAMPLE.cat) + '</p>';
    html += '<h1 class="pdp-title" data-jump="product_detail_title_font_size" style="font-size:' + s.title_font_size + 'px;">' + esc(SAMPLE.title) + '</h1>';
    html += '<div class="pdp-tags">';
    if (s.show_badges) {
      html += '<span class="pdp-tag" data-jump="product_detail_batch_verified_text">' + esc(s.batch_verified_text) + '</span>';
    }
    html += '<span class="pdp-tag">IN STOCK</span>';
    html += '</div>';
    html += '<p class="pdp-desc" data-jump="product_detail_body_font_size" style="font-size:' + s.body_font_size + 'px;">' + esc(SAMPLE.desc) + '</p>';
    html += '<div class="pdp-price" data-jump="product_detail_bg_navy">' + esc(SAMPLE.price) + '</div>';
    html += '<div class="pdp-qty-row"><span class="pdp-qty">1</span><span class="pdp-add-btn"><i class="fa fa-cart-shopping"></i> 加入购物车</span></div>';
    if (s.show_trust_box) {
      html += '<ul class="pdp-trust" data-jump="product_detail_show_trust_box">';
      for (var t = 0; t < s.trust_items.length; t++) {
        if (s.trust_items[t]) {
          html += '<li><i class="fa fa-check-circle"></i> ' + esc(s.trust_items[t]) + '</li>';
        }
      }
      html += '</ul>';
    }
    html += '</div>'; // pdp-info
    html += '</div>'; // pdp-buy

    if (s.show_tabs && s.tabs.length) {
      html += '<div class="pdp-tabs-section" data-jump="product_detail_show_tabs">';
      html += '<nav class="pdp-tab-nav">';
      for (var ti = 0; ti < s.tabs.length; ti++) {
        var lbl = s.tabs[ti].label || ('TAB ' + (ti + 1));
        html += '<button class="pdp-tab-link' + (ti === 0 ? ' active' : '') + '" data-jump="product_detail_tabs">' + esc(lbl) + '</button>';
      }
      html += '</nav>';
      for (var tj = 0; tj < s.tabs.length; tj++) {
        var tab = s.tabs[tj];
        var tabLabel = tab.label || ('TAB ' + (tj + 1));
        html += '<div class="pdp-tab-panel" data-jump="product_detail_tabs"><span class="pdp-panel-label">' + esc(tabLabel) + '</span>';
        if (tab.is_details) {
          // details tab: product description first, then the body, then specs
          html += '<p>' + esc(SAMPLE.desc) + '</p>';
          if (tab.body) { html += '<p>' + esc(tab.body) + '</p>'; }
          html += '<table class="pdp-spec-table" style="margin-top:8px;font-size:10px;"><tr><th>纯度</th><td>≥99%</td></tr><tr><th>装量</th><td>5mg</td></tr></table>';
        } else {
          html += '<p>' + esc(tab.body) + '</p>';
        }
        html += '</div>';
      }
      html += '</div>';
    }
    if (s.show_related) {
      html += '<div class="pdp-section" data-jump="product_detail_related_title">';
      html += '<p class="pdp-section-tag">// RELATED</p>';
      html += '<h2 class="pdp-section-title">' + esc(s.related_title) + '</h2>';
      html += '<div class="pdp-related-grid">';
      for (var i = 0; i < SAMPLE.related.length; i++) {
        var r = SAMPLE.related[i];
        html += '<div class="pdp-related-card"><div class="img-wrap">🧪</div><div class="body"><h3>' + esc(r.name) + '</h3><div class="price">' + esc(r.price) + '</div></div></div>';
      }
      html += '</div>';
      html += '</div>';
    }
    if (s.show_research) {
      html += '<div class="pdp-section" data-jump="product_detail_research_title">';
      html += '<p class="pdp-section-tag">// RESEARCH</p>';
      html += '<h2 class="pdp-section-title">' + esc(s.research_title) + '</h2>';
      html += '<div class="pdp-research-list">';
      for (var j = 0; j < s.research_links.length; j++) {
        if (s.research_links[j].label) {
          html += '<a class="pdp-research-item" data-jump="product_detail_research_links">' + esc(s.research_links[j].label) + '</a>';
        }
      }
      html += '</div>';
      html += '</div>';
    }
    html += '</div>'; // pdp-wrap
    return html;
  }

  function render() {
    var s = read();
    // 配色作用域化到预览画布 (不写 :root, 避免污染后台整体配色)
    frame.style.setProperty('--pdp-primary', s.primary_color);
    frame.style.setProperty('--pdp-bg-navy', s.bg_navy);
    frame.innerHTML = build(s);
  }

  form.addEventListener('input', render);
  form.addEventListener('change', render);
  render();

  // ===== Repeater management: add / remove / reindex rows =====
  // reindex rewrites the [index] in each data-name so tabs/research rows submit
  // as a clean 0..N array (trust_items[] is index-less, so it's left alone).
  function reindexRepeater(repeater) {
    var rows = repeater.querySelectorAll('.pdp-rep-row');
    rows.forEach(function (row, i) {
      row.querySelectorAll('[data-name]').forEach(function (el) {
        el.name = el.getAttribute('data-name').replace('{i}', i);
      });
    });
  }
  document.querySelectorAll('.pdp-rep-add').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var repeater = document.getElementById(btn.getAttribute('data-target'));
      var tpl = document.getElementById(btn.getAttribute('data-tpl'));
      if (!repeater || !tpl) return;
      repeater.appendChild(tpl.content.cloneNode(true));
      reindexRepeater(repeater);
      render();
    });
  });
  // Remove row (delegated; keep >=1 row so there is always one to edit).
  form.addEventListener('click', function (e) {
    if (!e.target.closest('.pdp-rep-remove')) return;
    var repeater = e.target.closest('.pdp-repeater');
    var row = e.target.closest('.pdp-rep-row');
    if (repeater && row && repeater.querySelectorAll('.pdp-rep-row').length > 1) {
      row.remove();
      reindexRepeater(repeater);
      render();
    }
  });
  // is_details is single-select: checking one unchecks the others, so the
  // product description + specifications render in exactly one tab.
  form.addEventListener('change', function (e) {
    if (!e.target.classList || !e.target.classList.contains('pdp-tab-is-details')) return;
    if (!e.target.checked) return;
    form.querySelectorAll('.pdp-tab-is-details').forEach(function (cb) {
      if (cb !== e.target) { cb.checked = false; }
    });
  });
  document.querySelectorAll('.pdp-repeater').forEach(reindexRepeater);

  // 点击预览各部分 -> 滚动到对应设置项并高亮
  frame.addEventListener('click', function (e) {
    var el = e.target.closest('[data-jump]');
    if (!el) return;
    e.preventDefault();
    var name = el.getAttribute('data-jump');
    var f = field(name);
    if (!f) return;
    var group = f.closest('.form-group') || f;
    var prev = document.querySelector('.pcard-jump-flash');
    if (prev) prev.classList.remove('pcard-jump-flash');
    void group.offsetWidth;
    group.classList.add('pcard-jump-flash');
    setTimeout(function () { group.classList.remove('pcard-jump-flash'); }, 1400);
    try { f.focus({ preventScroll: true }); } catch (_) { f.focus(); }
    // 滚动到吸顶类型栏下方, 避免字段被遮挡 (预览已改为浮窗, 不再叠加预览高度)
    var root = getComputedStyle(document.documentElement);
    var typebarH = parseFloat(root.getPropertyValue('--pdp-typebar-h')) || 52;
    var top = window.pageYOffset + group.getBoundingClientRect().top - (typebarH + 16);
    window.scrollTo({ top: Math.max(0, top), behavior: 'smooth' });
  });

  // 把吸顶类型栏高度写入 CSS 变量, 供 scroll-margin-top / 跳转滚动使用
  (function () {
    var typebar = document.querySelector('.pdp-typebar');
    var typebarH = 52;
    if (typebar) {
      var mb = parseInt(getComputedStyle(typebar).marginBottom) || 0;
      typebarH = typebar.offsetHeight + mb;
    }
    document.documentElement.style.setProperty('--pdp-typebar-h', typebarH + 'px');
  })();
})();
</script>
