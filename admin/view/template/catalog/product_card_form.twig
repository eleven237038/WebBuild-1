{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="submit" form="form-product-card" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa fa-save"></i> {{ button_save }}</button>
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i> {{ button_cancel }}</a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if error_warning %}
    <div class="alert alert-danger"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}<button type="button" class="close" data-dismiss="alert">&times;</button></div>
    {% endif %}
    {% if success %}
    <div class="alert alert-success"><i class="fa fa-check-circle"></i> {{ success }}<button type="button" class="close" data-dismiss="alert">&times;</button></div>
    {% endif %}

    {# 商品类型 chip bar: 切换编辑不同商品类型的卡片设置 (type 1 = 全局默认)
       sticky 顶部, 任何窗口大小/模式都始终可见 #}
    <div class="panel panel-default pcard-typebar" style="margin-bottom:12px;">
      <div class="panel-body" style="padding:8px 12px;">
        <div style="display:flex;align-items:center;gap:10px;">
          <span style="color:#64748b;font-weight:600;white-space:nowrap;">商品类型</span>
          <div style="display:flex;gap:8px;overflow-x:auto;padding:2px 0;white-space:nowrap;flex:1;">
            {% for pt in product_types %}
              <a href="{{ pt.url }}" class="btn btn-{{ pt.active ? 'primary' : 'default' }} btn-sm" style="white-space:nowrap;">{{ pt.name }}</a>
            {% endfor %}
          </div>
        </div>
      </div>
    </div>

    {# 复用前台 product-card.css (相对 admin 页面路径 ../catalog/...) + 共享浮窗样式 #}
    <link rel="stylesheet" href="../catalog/view/theme/default/stylesheet/genscript/product-card.css">
    <link rel="stylesheet" href="view/stylesheet/genscript/preview-float.css?v=20260723b">
    <style>
      {# 商品类型 chip bar: 始终吸顶可见 #}
      .pcard-typebar { position: sticky; top: 0; z-index: 1050; background: #fff; box-shadow: 0 2px 8px rgba(0,0,0,.06); }
      {# 表单占满宽度; 跳转滚动时为吸顶类型栏预留空间 #}
      .pcard-admin-form .form-group { scroll-margin-top: calc(var(--pcard-typebar-h, 52px) + 16px); }
      .pcard-preview-hint { font-size: 12px; color: #888; margin: 0 0 12px; }
      {# 预览画布: 居中展示一张卡片, 隔离配色变量 (不污染后台 :root) #}
      #pcard-preview-frame {
        --bg-navy: #0F172A;
        background: #ffffff;
        padding: 14px;
        border-radius: 10px;
        border: 1px solid #e8e8e8;
        min-height: 120px;
      }
      #pcard-preview-frame .product-card { max-width: 240px; margin: 0 auto; }
      #pcard-preview-frame .pcard-add:hover,
      #pcard-preview-frame .pcard-var:hover { background: var(--pcard-primary); }
      {# 点击预览各部分 -> 跳转并高亮对应编辑项 #}
      #pcard-preview-frame [data-jump] { cursor: pointer; }
      #pcard-preview-frame [data-jump]:hover { outline: 2px dashed var(--pcard-primary, #10B981); outline-offset: 3px; border-radius: 4px; }
      .pcard-jump-flash { border-radius: 4px; animation: pcard-jump-flash 1.4s ease-out; }
      @keyframes pcard-jump-flash {
        0%, 18% { background-color: #fff3cd; box-shadow: 0 0 0 3px rgba(255,193,7,.55); }
        100% { background-color: transparent; box-shadow: 0 0 0 0 transparent; }
      }
    </style>

    <div class="pcard-admin-form">
        <div class="panel panel-default">
          <div class="panel-heading">
            <h3 class="panel-title"><i class="fa fa-id-card-o"></i> {{ text_form }}</h3>
          </div>
          <div class="panel-body">
            <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-product-card" class="form-horizontal">

              <legend>{{ text_section_map }}</legend>
              <div class="form-group">
                <label class="col-sm-2 control-label">{{ entry_product_card_show_image }}</label>
                <div class="col-sm-10">
                  <select name="product_card_show_image" class="form-control" style="max-width:320px;">
                    <option value="" {{ product_card_show_image is empty ? 'selected' : '' }}>{{ text_none }}</option>
                    {% for fo in field_options %}
                    <option value="{{ fo.tag_id }}" {{ fo.tag_id == product_card_show_image ? 'selected' : '' }}>{{ fo.label }}</option>
                    {% endfor %}
                  </select>
                </div>
              </div>
              <div class="form-group">
                <label class="col-sm-2 control-label">{{ entry_product_card_show_name }}</label>
                <div class="col-sm-10">
                  <select name="product_card_show_name" class="form-control" style="max-width:320px;">
                    <option value="" {{ product_card_show_name is empty ? 'selected' : '' }}>{{ text_none }}</option>
                    {% for fo in field_options %}
                    <option value="{{ fo.tag_id }}" {{ fo.tag_id == product_card_show_name ? 'selected' : '' }}>{{ fo.label }}</option>
                    {% endfor %}
                  </select>
                </div>
              </div>
              <div class="form-group">
                <label class="col-sm-2 control-label">{{ entry_product_card_show_description }}</label>
                <div class="col-sm-10">
                  <select name="product_card_show_description" class="form-control" style="max-width:320px;">
                    <option value="" {{ product_card_show_description is empty ? 'selected' : '' }}>{{ text_none }}</option>
                    {% for fo in field_options %}
                    <option value="{{ fo.tag_id }}" {{ fo.tag_id == product_card_show_description ? 'selected' : '' }}>{{ fo.label }}</option>
                    {% endfor %}
                  </select>
                </div>
              </div>
              <div class="form-group">
                <label class="col-sm-2 control-label">{{ entry_product_card_show_price }}</label>
                <div class="col-sm-10">
                  <select name="product_card_show_price" class="form-control" style="max-width:320px;">
                    <option value="" {{ product_card_show_price is empty ? 'selected' : '' }}>{{ text_none }}</option>
                    {% for fo in field_options %}
                    <option value="{{ fo.tag_id }}" {{ fo.tag_id == product_card_show_price ? 'selected' : '' }}>{{ fo.label }}</option>
                    {% endfor %}
                  </select>
                </div>
              </div>
              <div class="form-group">
                <label class="col-sm-2 control-label">{{ entry_product_card_show_badges }}</label>
                <div class="col-sm-10">
                  <select name="product_card_show_badges" class="form-control" style="max-width:320px;">
                    <option value="" {{ product_card_show_badges is empty ? 'selected' : '' }}>{{ text_none }}</option>
                    {% for fo in field_options %}
                    <option value="{{ fo.tag_id }}" {{ fo.tag_id == product_card_show_badges ? 'selected' : '' }}>{{ fo.label }}</option>
                    {% endfor %}
                  </select>
                </div>
              </div>

              <legend>{{ text_section_toggle }}</legend>
              <div class="form-group">
                <label class="col-sm-2 control-label">{{ entry_product_card_show_wishlist }}</label>
                <div class="col-sm-10"><label class="checkbox-inline"><input type="checkbox" name="product_card_show_wishlist" value="1" {{ product_card_show_wishlist == 1 or product_card_show_wishlist == '1' ? 'checked' }}/> {{ entry_product_card_show_wishlist }}</label></div>
              </div>
              <div class="form-group">
                <label class="col-sm-2 control-label">{{ entry_product_card_show_add_button }}</label>
                <div class="col-sm-10"><label class="checkbox-inline"><input type="checkbox" name="product_card_show_add_button" value="1" {{ product_card_show_add_button == 1 or product_card_show_add_button == '1' ? 'checked' }}/> {{ entry_product_card_show_add_button }}</label></div>
              </div>

              <legend>{{ text_section_size }}</legend>
              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-image-height">{{ entry_product_card_image_height }}</label>
                <div class="col-sm-10"><input type="number" name="product_card_image_height" value="{{ product_card_image_height }}" id="input-image-height" class="form-control" style="max-width:200px;"></div>
              </div>
              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-desc-length">{{ entry_product_card_desc_length }}</label>
                <div class="col-sm-10"><input type="number" name="product_card_desc_length" value="{{ product_card_desc_length }}" id="input-desc-length" class="form-control" style="max-width:200px;"></div>
              </div>
              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-desc-clamp">{{ entry_product_card_desc_clamp }}</label>
                <div class="col-sm-10"><input type="number" name="product_card_desc_clamp" value="{{ product_card_desc_clamp }}" id="input-desc-clamp" class="form-control" style="max-width:200px;"></div>
              </div>
              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-name-fs">{{ entry_product_card_name_font_size }}</label>
                <div class="col-sm-10"><input type="number" name="product_card_name_font_size" value="{{ product_card_name_font_size }}" id="input-name-fs" class="form-control" style="max-width:200px;"></div>
              </div>
              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-price-fs">{{ entry_product_card_price_font_size }}</label>
                <div class="col-sm-10"><input type="number" name="product_card_price_font_size" value="{{ product_card_price_font_size }}" id="input-price-fs" class="form-control" style="max-width:200px;"></div>
              </div>

              <legend>{{ text_section_text }}</legend>
              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-add-btn">{{ entry_product_card_add_btn_text }}</label>
                <div class="col-sm-10"><input type="text" name="product_card_add_btn_text" value="{{ product_card_add_btn_text }}" id="input-add-btn" class="form-control" style="max-width:200px;"></div>
              </div>

              <legend>{{ text_section_color }}</legend>
              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-primary-color">{{ entry_product_card_primary_color }}</label>
                <div class="col-sm-10"><input type="color" name="product_card_primary_color" value="{{ product_card_primary_color }}" id="input-primary-color" class="form-control" style="max-width:80px;height:38px;padding:2px;"></div>
              </div>
              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-name-color">{{ entry_product_card_name_color }}</label>
                <div class="col-sm-10"><input type="color" name="product_card_name_color" value="{{ product_card_name_color }}" id="input-name-color" class="form-control" style="max-width:80px;height:38px;padding:2px;"></div>
              </div>
              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-price-color">{{ entry_product_card_price_color }}</label>
                <div class="col-sm-10"><input type="color" name="product_card_price_color" value="{{ product_card_price_color }}" id="input-price-color" class="form-control" style="max-width:80px;height:38px;padding:2px;"></div>
              </div>

              {# ===== 自定义徽章 repeater (动态增删, 存为 JSON 数组) ===== #}
              <legend>{{ entry_product_card_badges }}</legend>
              <div class="form-group">
                <label class="col-sm-2 control-label">{{ entry_product_card_badges }}</label>
                <div class="col-sm-10">
                  <div id="badges-repeater" class="pcard-repeater">
                    {% for b in product_card_badges %}
                    <div class="pcard-rep-row" style="display:flex;gap:8px;margin-bottom:8px;align-items:center;flex-wrap:wrap;">
                      <input type="text" name="product_card_badges[{{ loop.index0 }}][text]" data-name="product_card_badges[{i}][text]" value="{{ b.text }}" class="form-control pcard-badge-text" style="max-width:220px;" placeholder="{{ text_badge_text }}">
                      <label style="display:flex;align-items:center;gap:4px;font-weight:normal;margin:0;"><span style="font-size:12px;color:#888;">{{ text_badge_bg }}</span><input type="color" name="product_card_badges[{{ loop.index0 }}][bg]" data-name="product_card_badges[{i}][bg]" value="{{ b.bg }}" class="form-control pcard-badge-bg" style="width:44px;height:34px;padding:2px;"></label>
                      <label style="display:flex;align-items:center;gap:4px;font-weight:normal;margin:0;"><span style="font-size:12px;color:#888;">{{ text_badge_color }}</span><input type="color" name="product_card_badges[{{ loop.index0 }}][color]" data-name="product_card_badges[{i}][color]" value="{{ b.color }}" class="form-control pcard-badge-color" style="width:44px;height:34px;padding:2px;"></label>
                      <button type="button" class="btn btn-danger btn-sm pcard-rep-remove">{{ button_remove }}</button>
                    </div>
                    {% endfor %}
                  </div>
                  <template id="badge-row-tpl">
                    <div class="pcard-rep-row" style="display:flex;gap:8px;margin-bottom:8px;align-items:center;flex-wrap:wrap;">
                      <input type="text" name="product_card_badges[{i}][text]" data-name="product_card_badges[{i}][text]" value="" class="form-control pcard-badge-text" style="max-width:220px;" placeholder="{{ text_badge_text }}">
                      <label style="display:flex;align-items:center;gap:4px;font-weight:normal;margin:0;"><span style="font-size:12px;color:#888;">{{ text_badge_bg }}</span><input type="color" name="product_card_badges[{i}][bg]" data-name="product_card_badges[{i}][bg]" value="#10B981" class="form-control pcard-badge-bg" style="width:44px;height:34px;padding:2px;"></label>
                      <label style="display:flex;align-items:center;gap:4px;font-weight:normal;margin:0;"><span style="font-size:12px;color:#888;">{{ text_badge_color }}</span><input type="color" name="product_card_badges[{i}][color]" data-name="product_card_badges[{i}][color]" value="#ffffff" class="form-control pcard-badge-color" style="width:44px;height:34px;padding:2px;"></label>
                      <button type="button" class="btn btn-danger btn-sm pcard-rep-remove">{{ button_remove }}</button>
                    </div>
                  </template>
                  <button type="button" class="btn btn-default btn-sm pcard-rep-add" data-target="badges-repeater" data-tpl="badge-row-tpl">{{ button_add_badge }}</button>
                  <p style="font-size:12px;color:#888;margin-top:6px;">{{ text_badge_hint }}</p>
                </div>
              </div>

            </form>
          </div>
        </div>
      </div>

      {# ===== 实时预览浮窗 (可拖拽/最小化/关闭, 右上角固定) ===== #}
      <div id="pf-window" class="pf-window">
        <div class="pf-header" id="pf-header">
          <span class="pf-title"><i class="fa fa-eye"></i> {{ text_preview }}</span>
          <span class="pf-actions">
            <button type="button" class="pf-btn" id="pf-min" title="最小化"><i class="fa fa-minus"></i></button>
            <button type="button" class="pf-btn" id="pf-close" title="关闭"><i class="fa fa-times"></i></button>
          </span>
        </div>
        <div class="pf-body" id="pf-body">
          <p class="pcard-preview-hint">{{ text_preview_hint }}</p>
          <div id="pcard-preview-frame"></div>
        </div>
      </div>
      <button type="button" id="pf-fab" class="pf-fab" title="{{ text_preview }}"><i class="fa fa-eye"></i></button>
  </div>
</div>

<script src="view/javascript/genscript/preview-float.js?v=20260723b"></script>
<script>
(function () {
  // 示例商品数据 (用于预览渲染; 与前台 product_card.twig 结构保持一致)
  var SAMPLE = {
    name: 'BPC-157 高纯度合成多肽试剂',
    description: '本品为实验室级高纯度合成多肽试剂，纯度≥99%，适用于细胞培养与体外研究实验。每瓶5mg装量，-20°C避光保存，长期稳定性经验证。支持定制规格与批量订购，提供完整COA分析报告与质控数据，欢迎咨询客服获取技术资料。',
    price: '¥299.00',
    thumb: "data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 120 120'><g fill='none' stroke='%23ffffff' stroke-width='3.5' stroke-linecap='round'><circle cx='42' cy='42' r='13'/><circle cx='82' cy='42' r='13'/><circle cx='62' cy='82' r='13'/><line x1='42' y1='42' x2='82' y2='42'/><line x1='42' y1='42' x2='62' y2='82'/><line x1='82' y1='42' x2='62' y2='82'/></g></svg>",
    tags: [
      { parent: '类别', name: '多肽试剂' },
      { parent: '纯度', name: '≥99%' }
    ]
  };

  var form = document.getElementById('form-product-card');
  var frame = document.getElementById('pcard-preview-frame');
  if (!form || !frame) return;

  function chk(name) {
    var el = form.querySelector('input[name="' + name + '"]');
    return el && el.checked ? 1 : 0;
  }
  // 字段映射下拉: 非空白 = 显示该槽位 (1), 空白 = 隐藏 (0)
  function sel(name) {
    var el = form.querySelector('select[name="' + name + '"]');
    return el && el.value !== '' ? 1 : 0;
  }
  function num(name, def) {
    var el = form.querySelector('input[name="' + name + '"]');
    var v = el ? parseInt(el.value, 10) : NaN;
    return isNaN(v) ? def : v;
  }
  function val(name, def) {
    var el = form.querySelector('input[name="' + name + '"]');
    return el && el.value !== '' ? el.value : def;
  }

  function read() {
    // 自定义徽章: 从 repeater DOM 读取 (text + bg + color), 保留空行供预览即时反映
    var badges = [];
    form.querySelectorAll('#badges-repeater .pcard-rep-row').forEach(function (row) {
      var t = row.querySelector('.pcard-badge-text');
      var b = row.querySelector('.pcard-badge-bg');
      var c = row.querySelector('.pcard-badge-color');
      badges.push({
        text:  t ? t.value : '',
        bg:    b ? b.value : '#10B981',
        color: c ? c.value : '#ffffff'
      });
    });
    return {
      show_image: sel('product_card_show_image'),
      show_name: sel('product_card_show_name'),
      show_description: sel('product_card_show_description'),
      show_price: sel('product_card_show_price'),
      show_wishlist: chk('product_card_show_wishlist'),
      show_badges: sel('product_card_show_badges'),
      show_add_button: chk('product_card_show_add_button'),
      image_height: num('product_card_image_height', 200),
      desc_length: num('product_card_desc_length', 100),
      desc_clamp: num('product_card_desc_clamp', 2),
      name_font_size: num('product_card_name_font_size', 15),
      price_font_size: num('product_card_price_font_size', 22),
      add_btn_text: val('product_card_add_btn_text', '+'),
      primary_color: val('product_card_primary_color', '#10B981'),
      name_color: val('product_card_name_color', '#0F172A'),
      price_color: val('product_card_price_color', '#10B981'),
      badges: badges
    };
  }

  function esc(s) {
    return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  // 构建卡片 HTML - 严格对应 catalog/.../product/product_card.twig 的渲染分支
  // (article + pcard-badge--tag + pcard-name-link + pcard-price-wrap)。
  // 数据驱动的增强位 (SALE/OUT OF STOCK/评分) 依赖具体商品数据, 非后台配置项,
  // 故预览只反映可配置的 5 内容位 + 2 开关 + 尺寸 + 配色。
  // 每个可点部分带 data-jump, 点击跳转到对应设置项
  function build(s) {
    var html = '<article class="product-card">';
    // 自定义徽章 (repeater; 空文字行不渲染, 与前台 product_card.twig 的空文字过滤一致)
    if (s.badges && s.badges.length) {
      s.badges.forEach(function (cb) {
        if (!cb.text) return;
        html += '<span class="pcard-badge pcard-badge--custom" data-jump="product_card_badges" style="background:' + esc(cb.bg) + ';color:' + esc(cb.color) + ';">' + esc(cb.text) + '</span>';
      });
    }
    // 动态标签徽章 (单字段映射: 预览取首个示例标签)
    if (s.show_badges) {
      var t = SAMPLE.tags[0];
      html += '<span class="pcard-badge pcard-badge--tag" data-jump="product_card_show_badges">' + esc((t.parent ? t.parent + ': ' : '') + t.name) + '</span>';
    }
    // 图片区
    if (s.show_image) {
      html += '<a href="#" class="pcard-img-wrap" data-jump="product_card_show_image" style="height:' + s.image_height + 'px;">';
      if (s.show_wishlist) {
        html += '<button class="pcard-wishlist" type="button" data-jump="product_card_show_wishlist" aria-label="Wishlist"><i class="fa-regular fa-heart"></i></button>';
      }
      html += '<img src="' + SAMPLE.thumb + '" alt="' + esc(SAMPLE.name) + '" loading="lazy">';
      html += '</a>';
    }
    // 卡片正文
    html += '<div class="pcard-body">';
    if (s.show_name) {
      html += '<a href="#" class="pcard-name-link" data-jump="product_card_show_name"><h3 class="pcard-name" style="font-size:' + s.name_font_size + 'px;">' + esc(SAMPLE.name) + '</h3></a>';
    }
    if (s.show_description) {
      var desc = SAMPLE.description;
      html += '<p class="pcard-desc" data-jump="product_card_show_description" style="-webkit-line-clamp:' + s.desc_clamp + ';">';
      html += desc.length > s.desc_length ? esc(desc.substr(0, s.desc_length)) + '…' : esc(desc);
      html += '</p>';
    }
    if (s.show_price || s.show_add_button) {
      html += '<div class="pcard-bottom">';
      if (s.show_price) {
        html += '<div class="pcard-price-wrap"><span class="pcard-price" data-jump="product_card_show_price" style="font-size:' + s.price_font_size + 'px;">' + esc(SAMPLE.price) + '</span></div>';
      }
      if (s.show_add_button) {
        html += '<button class="pcard-add" type="button" data-jump="product_card_show_add_button">' + esc(s.add_btn_text) + '</button>';
      }
      html += '</div>';
    }
    html += '</div></article>';
    return html;
  }

  function render() {
    var s = read();
    // 配色作用域化到预览画布 (不写 :root, 避免污染后台整体配色)
    frame.style.setProperty('--pcard-primary', s.primary_color);
    frame.style.setProperty('--pcard-name-color', s.name_color);
    frame.style.setProperty('--pcard-price-color', s.price_color);
    frame.style.setProperty('--bg-navy', '#0F172A');
    frame.innerHTML = build(s);
  }

  form.addEventListener('input', render);
  form.addEventListener('change', render);
  render();

  // ===== 自定义徽章 repeater 管理 (克隆模板 + 重排索引 + 删除行) =====
  // reindex 把 data-name 里的 {i} 替换为行序号, 保证提交为 0..N 干净数组
  function reindexRepeater(repeater) {
    repeater.querySelectorAll('.pcard-rep-row').forEach(function (row, i) {
      row.querySelectorAll('[data-name]').forEach(function (el) {
        el.name = el.getAttribute('data-name').replace('{i}', i);
      });
    });
  }
  document.querySelectorAll('.pcard-rep-add').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var repeater = document.getElementById(btn.getAttribute('data-target'));
      var tpl = document.getElementById(btn.getAttribute('data-tpl'));
      if (!repeater || !tpl) return;
      repeater.appendChild(tpl.content.cloneNode(true));
      reindexRepeater(repeater);
      render();
    });
  });
  // 删除行 (委托; 保留 >=1 行以便始终可编辑)
  form.addEventListener('click', function (e) {
    if (!e.target.closest('.pcard-rep-remove')) return;
    var repeater = e.target.closest('.pcard-repeater');
    var row = e.target.closest('.pcard-rep-row');
    if (repeater && row && repeater.querySelectorAll('.pcard-rep-row').length > 1) {
      row.remove();
      reindexRepeater(repeater);
      render();
    }
  });
  document.querySelectorAll('.pcard-repeater').forEach(reindexRepeater);

  // 点击预览各部分 -> 滚动到对应设置项并高亮
  frame.addEventListener('click', function (e) {
    var el = e.target.closest('[data-jump]');
    if (!el) return;
    e.preventDefault();
    var name = el.getAttribute('data-jump');
    var field = form.querySelector('[name="' + name + '"]');
    // repeater 字段 (如 product_card_badges) 没有精确 name 匹配 -> 取首个 [N][...] 输入
    if (!field) { field = form.querySelector('[name^="' + name + '["]'); }
    if (!field) return;
    var group = field.closest('.form-group') || field;
    // 清掉残留高亮, 重启动画
    var prev = document.querySelector('.pcard-jump-flash');
    if (prev) prev.classList.remove('pcard-jump-flash');
    void group.offsetWidth;
    group.classList.add('pcard-jump-flash');
    setTimeout(function () { group.classList.remove('pcard-jump-flash'); }, 1400);
    try { field.focus({ preventScroll: true }); } catch (_) { field.focus(); }
    // 滚动到吸顶类型栏下方, 避免字段被遮挡 (预览已改为浮窗, 不再叠加预览高度)
    var root = getComputedStyle(document.documentElement);
    var typebarH = parseFloat(root.getPropertyValue('--pcard-typebar-h')) || 52;
    var top = window.pageYOffset + group.getBoundingClientRect().top - (typebarH + 16);
    window.scrollTo({ top: Math.max(0, top), behavior: 'smooth' });
  });

  // 把吸顶类型栏高度写入 CSS 变量, 供 scroll-margin-top / 跳转滚动使用
  (function () {
    var typebar = document.querySelector('.pcard-typebar');
    var typebarH = 52;
    if (typebar) {
      var mb = parseInt(getComputedStyle(typebar).marginBottom) || 0;
      typebarH = typebar.offsetHeight + mb;
    }
    document.documentElement.style.setProperty('--pcard-typebar-h', typebarH + 'px');
  })();
})();
</script>
