{{ header }}{{ column_left }}
{% if modal %}<style>#header,#column-left,#footer{display:none !important;} #content{margin-left:0 !important; margin-top:0 !important; padding:0 0 12px !important;} body{background:#fff !important; padding-top:0 !important;} .page-header{margin-top:0 !important;}</style>{% endif %}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="submit" form="form-tag" data-toggle="tooltip" title="保存" class="btn btn-primary"><i class="fa fa-save"></i></button>
        <a href="{{ cancel }}" data-toggle="tooltip" title="取消" class="btn btn-default"{% if modal %} onclick="parent.closeModalForm();return false;"{% endif %}><i class="fa fa-reply"></i></a>
      </div>
      <h1>{{ heading }}</h1>
    </div>
  </div>
  <div class="container-fluid">
    {% if error_warning %}<div class="alert alert-danger"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}</div>{% endif %}
    <div class="panel panel-default">
      <div class="panel-body">
        <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-tag" class="form-horizontal">
          <input type="hidden" name="product_type_id" value="{{ product_type_id }}"/>
          {% if modal %}<input type="hidden" name="modal" value="1"/>{% endif %}

          <div class="form-group required">
            <label class="col-sm-2 control-label" for="input-name">前端显示</label>
            <div class="col-sm-10">
              <input type="text" name="name" value="{{ name }}" id="input-name" class="form-control" maxlength="64"/>
              <div class="help-block">前台 (商品卡片/规格列表/筛选) 显示的字段名称</div>
              {% if error_name %}<div class="text-danger">{{ error_name }}</div>{% endif %}
            </div>
          </div>

          <div class="form-group required">
            <label class="col-sm-2 control-label" for="input-display-label">后端显示</label>
            <div class="col-sm-10">
              <input type="text" name="display_label" value="{{ display_label }}" id="input-display-label" class="form-control" maxlength="128"/>
              <div class="help-block">后台商品表单显示的标签</div>
              {% if error_display_label %}<div class="text-danger">{{ error_display_label }}</div>{% endif %}
            </div>
          </div>

          <div class="form-group" id="fg-parent">
            <label class="col-sm-2 control-label" for="input-parent">父字段</label>
            <div class="col-sm-10">
              <select name="parent_id" id="input-parent" class="form-control">
                <option value="0">-- 顶级字段 --</option>
                {% for opt in parent_options %}
                <option value="{{ opt.tag_id }}" data-depth="{{ opt.depth is defined ? opt.depth : 0 }}" {{ parent_id == opt.tag_id ? 'selected' }}>{{ opt.name }}</option>
                {% endfor %}
              </select>
              <div class="help-block">仅"结构体"类型的字段可作为父字段;结构体可嵌套子结构体(最多 3 层)。也可在列表页拖拽调整。</div>
              {% if error_parent %}<div class="text-danger">{{ error_parent }}</div>{% endif %}
            </div>
          </div>

          <div class="form-group required">
            <label class="col-sm-2 control-label" for="input-tag-type">类型</label>
            <div class="col-sm-10">
              <select name="tag_type" id="input-tag-type" class="form-control">
                <option value="text"     {{ tag_type == 'text'     ? 'selected' }}>文本</option>
                <option value="textarea" {{ tag_type == 'textarea' ? 'selected' }}>多行文本</option>
                <option value="number"   {{ tag_type == 'number'   ? 'selected' }}>数字</option>
                <option value="date"     {{ tag_type == 'date'     ? 'selected' }}>日期</option>
                <option value="image_single" {{ tag_type == 'image_single' ? 'selected' }}>单张图片</option>
                <option value="image_multi"  {{ tag_type == 'image_multi'  ? 'selected' }}>多张图片</option>
                <option value="select"   {{ tag_type == 'select'   ? 'selected' }}>下拉选择</option>
                <option value="struct"   {{ tag_type == 'struct'   ? 'selected' }}>结构体</option>
              </select>
              <div class="help-block" id="type-hint-struct" style="display:none;">结构体是容器字段,本身不存值;在列表页拖拽其它字段到其下即建立父子分组。结构体可嵌套子结构体,最多 3 层。</div>
              {% if error_tag_type %}<div class="text-danger">{{ error_tag_type }}</div>{% endif %}
            </div>
          </div>

          {# ── 类型专属配置区 (JS 按 tag_type 显隐) ── #}
          <div class="form-group type-config" data-for="select" style="display:none;">
            <label class="col-sm-2 control-label">下拉选项</label>
            <div class="col-sm-10">
              <div id="option-rows" style="margin-bottom:8px;">
                {% for opt in tag_options %}
                <div class="opt-row" style="display:flex;gap:6px;margin-bottom:6px;">
                  <input type="text" name="options[text][]" value="{{ opt.text != '' ? opt.text : opt.value }}" class="form-control" placeholder="选项文字" style="flex:1;"/>
                  <button type="button" class="btn btn-danger opt-remove"><i class="fa fa-times"></i></button>
                </div>
                {% endfor %}
              </div>
              <button type="button" class="btn btn-default btn-sm" id="opt-add"><i class="fa fa-plus"></i> 添加选项</button>
              <div class="help-block">每个选项既是存入数据库的值,也是商品表单与前台规格展示的文字。留空全部选项则作为 是/否 布尔下拉。</div>
            </div>
          </div>

          <div class="form-group type-config" data-for="number" style="display:none;">
            <label class="col-sm-2 control-label">数字配置</label>
            <div class="col-sm-10">
              <div style="display:flex;gap:8px;flex-wrap:wrap;">
                <div style="flex:1;min-width:120px;"><input type="text" name="config_unit" value="{{ config_unit }}" class="form-control" placeholder="单位 (如 mg)"/></div>
                <div style="flex:1;min-width:100px;"><input type="number" name="config_min" value="{{ config_min }}" class="form-control" placeholder="最小值" step="any"/></div>
                <div style="flex:1;min-width:100px;"><input type="number" name="config_max" value="{{ config_max }}" class="form-control" placeholder="最大值" step="any"/></div>
              </div>
              <div class="help-block">单位会作为后缀显示在输入框旁;最小/最大约束商品表单的数字输入 (步长不限制)。全部可选。</div>
            </div>
          </div>

          <div class="form-group type-config" data-for="text" style="display:none;">
            <label class="col-sm-2 control-label">文本配置</label>
            <div class="col-sm-10">
              <input type="text" name="config_placeholder" value="{{ config_placeholder }}" class="form-control" placeholder="占位符 (输入框灰字提示)"/>
              <div class="help-block">占位符显示在输入框内作为提示;最大长度不限制。可选。</div>
            </div>
          </div>

          <div class="form-group type-config" data-for="textarea" style="display:none;">
            <label class="col-sm-2 control-label">多行文本配置</label>
            <div class="col-sm-10">
              <input type="text" name="config_placeholder" value="{{ config_placeholder }}" class="form-control" placeholder="占位符 (输入框灰字提示)"/>
              <div class="help-block">占位符显示在编辑器上方作为输入提示。可选。</div>
            </div>
          </div>

          <div class="form-group type-config" data-for="image_multi" style="display:none;">
            <label class="col-sm-2 control-label">多图配置</label>
            <div class="col-sm-10">
              <input type="number" name="config_max_count" value="{{ config_max_count }}" class="form-control" placeholder="最大数量 (0 或留空表示不限)" min="0" style="max-width:240px;"/>
              <div class="help-block">商品表单添加图片时不超过此数量。可选。</div>
            </div>
          </div>

          <div class="form-group" id="fg-required">
            <label class="col-sm-2 control-label">是否必填</label>
            <div class="col-sm-10">
              <label class="checkbox-inline"><input type="checkbox" name="is_required" value="1" {{ is_required == 1 ? 'checked' }}/> 启用必填校验</label>
            </div>
          </div>

        </form>
      </div>
    </div>
  </div>
</div>
<script type="text/javascript"><!--
$(function () {
  var $type = $('#input-tag-type');

  // 按 tag_type 显隐类型专属配置 + 必填 (结构体隐藏)。结构体现可嵌套, 父字段下拉恒显示。
  // 隐藏块的 input 必须 disable, 否则仍会随表单提交 (select 同名数组会重复)
  function syncTypeUI() {
    var t = $type.val();
    $('.type-config').each(function () {
      var show = ($(this).data('for') === t);
      $(this).toggle(show);
      $(this).find('input, select, textarea').prop('disabled', !show);
    });
    var isStruct = (t === 'struct');
    $('#fg-required').toggle(!isStruct);
    $('#type-hint-struct').toggle(isStruct);
    // 结构体作子时父结构体深度须 <= 1 (子结构体 depth <= 2, 即最多 3 层); 普通字段可挂任意结构体下
    gateParentOptions(isStruct);
  }

  // 按当前类型限制父字段可选范围: 结构体仅可选 depth<=1 的结构体作父; 普通字段不限
  function gateParentOptions(isStruct) {
    $('#input-parent option').each(function () {
      var $o = $(this);
      if ($o.val() === '0') { return; }                 // "-- 顶级字段 --" 恒可选
      var d = parseInt($o.data('depth'), 10) || 0;
      $o.prop('disabled', isStruct && d >= 2);
    });
    // 当前选中项被禁用时回退到顶级
    if ($('#input-parent option:selected').prop('disabled')) {
      $('#input-parent').val('0');
    }
  }

  // select 选项行增删
  function bindOptionRows(containerSel, addBtnSel) {
    var $cont = $(containerSel);
    $(addBtnSel).on('click', function () {
      var row = '<div class="opt-row" style="display:flex;gap:6px;margin-bottom:6px;">' +
        '<input type="text" name="options[text][]" class="form-control" placeholder="选项文字" style="flex:1;"/>' +
        '<button type="button" class="btn btn-danger opt-remove"><i class="fa fa-times"></i></button>' +
        '</div>';
      $cont.append(row);
    });
  }
  bindOptionRows('#option-rows', '#opt-add');

  // 删除选项行 (至少保留 1 行? 不强求, 空选项会被服务端忽略)
  $(document).on('click', '.opt-remove', function () {
    $(this).closest('.opt-row').remove();
  });

  $type.on('change', syncTypeUI);
  syncTypeUI();
});
//--></script>
{{ footer }}
