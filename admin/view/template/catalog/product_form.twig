<link rel="stylesheet" href="view/javascript/cropper/cropper.min.css"/>
<script src="view/javascript/cropper/cropper.min.js"></script>
<div class="modal fade" id="modal-crop" tabindex="-1" role="dialog" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <button type="button" class="close" data-dismiss="modal" aria-label="{{ button_close|default('关闭') }}"><span aria-hidden="true">&times;</span></button>
        <h4 class="modal-title">上传并裁剪图片</h4>
      </div>
      <div class="modal-body">
        <div style="margin-bottom:12px;">
          <input type="file" id="crop-file" accept="image/png, image/jpeg, image/gif"/>
          <span style="color:#999;margin-left:8px;">选择图片后可拖拽裁剪框, 输出为固定 600×600 正方形</span>
        </div>
        <div style="max-width:520px;max-height:420px;overflow:hidden;background:#f5f5f5;">
          <img id="crop-image" src="" style="max-width:100%;display:none;"/>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-default" data-dismiss="modal">{{ button_cancel|default('取消') }}</button>
        <button type="button" id="crop-confirm" class="btn btn-primary" data-loading-text="保存中...">确认裁剪并保存</button>
      </div>
    </div>
  </div>
</div>
<script type="text/javascript"><!--
$(function () {
  var cropper = null;
  var cropTarget = null;

  // 点击主图缩略图 -> 打开裁剪弹窗 (头像式上传)
  $(document).on('click', '[data-toggle="crop"]', function (e) {
    e.preventDefault();
    cropTarget = $(this);
    if (cropper) { cropper.destroy(); cropper = null; }
    $('#crop-image').attr('src', '').hide();
    $('#crop-file').val('');
    $('#modal-crop').modal('show');
  });

  // 选择文件 -> 初始化 Cropper (1:1 固定比例, 头像式)
  $('#crop-file').on('change', function (e) {
    var f = e.target.files[0];
    if (!f) return;
    var reader = new FileReader();
    reader.onload = function (ev) {
      $('#crop-image').attr('src', ev.target.result).show();
      if (cropper) { cropper.destroy(); }
      cropper = new Cropper(document.getElementById('crop-image'), {
        aspectRatio: 1,
        viewMode: 1,
        autoCropArea: 1,
        background: false,
        movable: true,
        zoomable: true,
        rotatable: false,
        scalable: false
      });
    };
    reader.readAsDataURL(f);
  });

  // 确认 -> 裁剪为 600x600 -> 上传 -> 更新主图缩略图与隐藏域
  $('#crop-confirm').on('click', function () {
    if (!cropper) { alert('请先选择图片'); return; }
    var canvas = cropper.getCroppedCanvas({ width: 600, height: 600 });
    if (!canvas) { alert('裁剪失败, 请重新选择图片'); return; }
    var dataUrl = canvas.toDataURL('image/jpeg', 0.9);
    var $btn = $('#crop-confirm');
    $.ajax({
      url: 'index.php?route=common/filemanager/crop&user_token={{ user_token }}',
      type: 'post',
      data: { file: dataUrl },
      dataType: 'json',
      beforeSend: function () { $btn.button('loading'); },
      complete: function () { $btn.button('reset'); },
      success: function (json) {
        if (json['code'] == 1 && json['result']) {
          var r = json['result'][0];
          var mode = cropTarget.attr('data-crop-mode') || 'single';
          if (mode === 'multi-add') {
            // 多张图片: 新增图位, 追加到图位列表末尾
            var $group = cropTarget.closest('.img-multi-group');
            var maxCount = parseInt($group.data('max-count') || 0, 10);
            if (maxCount > 0 && $group.find('.img-multi-list .img-multi-item').length >= maxCount) {
              alert('该字段最多 ' + maxCount + ' 张图片');
              $('#modal-crop').modal('hide');
              return;
            }
            var slot = $('<span class="img-multi-item" style="display:inline-block;position:relative;">' +
              '<a href="" data-toggle="crop" data-crop-mode="multi" class="img-thumbnail" data-path="' + r['image'] + '">' +
              '<img src="' + r['thumb'] + '" alt="" title="" style="max-width:100px;max-height:100px;"/>' +
              '</a>' +
              '<button type="button" class="btn btn-danger btn-xs img-multi-remove" style="position:absolute;top:-6px;right:-6px;border-radius:50%;padding:0 5px;line-height:1.2;"><i class="fa fa-times"></i></button>' +
              '</span>');
            $group.find('.img-multi-list').append(slot);
            rebuildMulti($group);
          } else if (mode === 'multi') {
            // 多张图片: 替换当前图位
            cropTarget.find('img').attr('src', r['thumb']);
            cropTarget.attr('data-path', r['image']);
            rebuildMulti(cropTarget.closest('.img-multi-group'));
          } else {
            // 单张图片 / 主图: 替换缩略图与隐藏域
            cropTarget.find('img').attr('src', r['thumb']);
            cropTarget.next('input').val(r['image']);
          }
          $('#modal-crop').modal('hide');
        } else {
          alert(json['error'] ? json['error'] : '保存失败');
        }
      },
      error: function () { alert('网络错误, 保存失败'); }
    });
  });

  // 多张图片: 删除某个图位
  $(document).on('click', '.img-multi-remove', function (e) {
    e.preventDefault();
    e.stopPropagation();
    var group = $(this).closest('.img-multi-group');
    $(this).closest('.img-multi-item').remove();
    rebuildMulti(group);
  });

  // 多张图片: 根据所有图位 data-path 重建隐藏域 (逗号分隔)
  function rebuildMulti(group) {
    var paths = [];
    group.find('.img-multi-list .img-multi-item a').each(function () {
      var p = $(this).attr('data-path');
      if (p) { paths.push(p); }
    });
    group.find('input[type=hidden]').val(paths.join(','));
  }

  // 关闭弹窗时清理 Cropper 实例
  $('#modal-crop').on('hidden.bs.modal', function () {
    if (cropper) { cropper.destroy(); cropper = null; }
    $('#crop-file').val('');
  });
});
//--></script>
{{ footer }}
