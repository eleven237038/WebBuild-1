{{ header }}{{ column_left }}
{% if modal %}<style>#header,#column-left,#footer{display:none !important;} #content{margin-left:0 !important; margin-top:0 !important; padding:0 0 12px !important;} body{background:#fff !important; padding-top:0 !important;} .page-header{margin-top:0 !important;}</style>{% endif %}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="submit" form="form-product" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa fa-save"></i></button>
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"{% if modal %} onclick="parent.closeModalForm();return false;"{% endif %}><i class="fa fa-reply"></i></a></div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">{% if error_warning %}
      <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
        <button type="button" class="close" data-dismiss="alert">&times;</button>
      </div>
    {% endif %}
    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-pencil"></i> {{ text_form }}</h3>
      </div>
      <div class="panel-body">
        <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-product" class="form-horizontal">
          {% if modal %}<input type="hidden" name="modal" value="1"/>{% endif %}
          {% import "catalog/_eav_field_render.twig" as eav %}
          {% set eav_ui = {
            placeholder: placeholder|default(''),
            image_base: image_base|default(''),
            yes: text_yes|default('是'),
            no: text_no|default('否'),
            select: text_select|default('-- 请选择 --'),
            summernote: summernote|default('en-gb'),
            entry_additional_image: entry_additional_image|default('附加图片'),
            entry_sort_order: entry_sort_order|default('排序')
          } %}
          {# 整个表单内容完全由 custom_tag (自定义字段) 驱动, 按 sort_order 顺序渲染;
             添加商品 / 编辑商品 共用同一 getForm(), 已统一。原 General / Image 硬编码标签页已删除,
             其字段 (商品描述 / Meta / 标签 / 主图) 迁移为带 system_column 的 custom_tag 记录, 可拖拽排序。 #}
          {# 统一渲染所有字段 (预序: 结构体紧跟其子字段): 有 system_column 走真实列, 否则走 EAV。
             结构体 (tag_type=struct) 作为可视容器, 开 fieldset 把其后 parent_id=该结构体 的子字段包起来。 #}
          <div class="form-group required" style="border:1px solid #e2e8f0;border-radius:4px;padding:12px 16px;margin-bottom:14px;background:#f8fafc;">
            <label class="col-sm-2 control-label" for="input-product-type">商品类型</label>
            <div class="col-sm-10">
              <select name="product_type_id" id="input-product-type" class="form-control" style="max-width:360px;">
                {% for pt in product_types %}
                  <option value="{{ pt.product_type_id }}" {% if product_type_id == pt.product_type_id %}selected="selected"{% endif %}>{{ pt.name }}</option>
                {% endfor %}
              </select>
              <span style="display:block;margin-top:4px;color:#94a3b8;font-size:12px;">选择商品所属类型, 用于商品管理页按类型筛选。</span>
            </div>
          </div>
          {% if form_fields is not empty %}
            <fieldset>
              {% for field in form_fields %}
                {# close_before: 关闭已离开的 struct fieldset (嵌套层级回退; 控制器按 parent_id 栈预算) #}
                {% set _cb = field.close_before|default(0) %}
                {% if _cb %}{% for i in 1.._cb %}</fieldset>{% endfor %}{% endif %}
                {# 结构体字段: 开新 fieldset 分组 (结构体本身不渲染输入; 可嵌套子结构体最多 3 层) #}
                {% if field.tag_type is defined and field.tag_type == 'struct' %}
                  <fieldset class="struct-group" data-type-id="{{ field.product_type_id }}" data-is-system="0" style="border:1px solid #e2e8f0;border-radius:4px;padding:12px 16px 4px;margin:12px 0;">
                    <legend style="font-size:14px;font-weight:600;color:#334155;width:auto;border-bottom:none;padding:0 8px;margin-bottom:8px;">{{ field.name }}</legend>
                {% else %}
                <div class="ff-row" data-type-id="{{ field.product_type_id }}" data-is-system="{{ field.system_column is not empty ? 1 : 0 }}">
                {% if field.system_column is not empty %}
                {% if field.field_type == 'core_text_ml' %}
                  {# 多语言系统字段 (商品名称/描述/Meta标题/Meta描述/Meta关键字/商品标签):
                     修复"中英重复输入两次"bug: 详情页仅保留中文(zh-cn)输入框, 不再堆叠 en-gb。
                     保存时控制器 mirrorChineseToAllLanguages() 把中文值镜像写入 en-gb 等其他语言行,
                     避免 editProduct 的 DELETE+重插 丢失英文行 (否则 en-gb 前台商品名为空)。
                     DB 已为 utf8mb4, 中文存取正常; 控制器/模型 SQL 无需改动。 #}
                  {% set zh_lang = null %}
                  {% for language in languages %}
                    {% if zh_lang is null and language.code starts with 'zh' %}{% set zh_lang = language %}{% endif %}
                  {% endfor %}
                  {% if zh_lang is null %}{% set zh_lang = languages|first %}{% endif %}
                  {% set lval = product_description[zh_lang.language_id] is defined and product_description[zh_lang.language_id][field.system_column] is defined ? product_description[zh_lang.language_id][field.system_column] : '' %}
                  <div class="form-group{% if field.is_required %} required{% endif %}">
                    <label class="col-md-2 control-label" for="input-{{ field.system_column }}{{ zh_lang.language_id }}">{{ field.display_label is defined and field.display_label is not empty ? field.display_label : field.name }}</label>
                    <div class="col-md-10">
                      {% if field.tag_type == 'textarea' %}
                        <textarea name="product_description[{{ zh_lang.language_id }}][{{ field.system_column }}]" rows="5" id="input-{{ field.system_column }}{{ zh_lang.language_id }}" class="form-control{% if field.input_type == 'summernote' %} tinymce{% endif %}" data-toggle="" data-lang="{{ summernote|default('en-gb') }}" placeholder="{{ field.display_label is defined and field.display_label is not empty ? field.display_label : field.name }}">{{ lval }}</textarea>
                      {% else %}
                        <input type="text" name="product_description[{{ zh_lang.language_id }}][{{ field.system_column }}]" value="{{ lval }}" id="input-{{ field.system_column }}{{ zh_lang.language_id }}" class="form-control" placeholder="{{ field.display_label is defined and field.display_label is not empty ? field.display_label : field.name }}"/>
                      {% endif %}
                      {% if field.system_column == 'name' and error_name[zh_lang.language_id] is defined and error_name[zh_lang.language_id] %}
                        <div class="text-danger">{{ error_name[zh_lang.language_id] }}</div>
                      {% elseif field.system_column == 'meta_title' and error_meta_title[zh_lang.language_id] is defined and error_meta_title[zh_lang.language_id] %}
                        <div class="text-danger">{{ error_meta_title[zh_lang.language_id] }}</div>
                      {% endif %}
                    </div>
                  </div>
                {% elseif field.system_column == 'image' %}
                  {# 商品主图 (单张图片, 头像式裁剪): input name="image" -> oc_product.image。附加图功能已移除。 #}
                  <div class="form-group">
                    <label class="col-md-2 control-label">{{ field.display_label is defined and field.display_label is not empty ? field.display_label : field.name }}</label>
                    <div class="col-md-10">
                      <a href="" id="thumb-image" data-toggle="crop" class="img-thumbnail"><img src="{{ thumb }}" alt="" title="" data-placeholder="{{ placeholder }}"/></a>
                      <input type="hidden" name="image" value="{{ image }}" id="input-image"/>
                    </div>
                  </div>
                {% else %}
                  {{ eav.renderField(field, _context[field.system_column] is defined ? _context[field.system_column] : '', field.system_column, product_images, field.system_column, eav_ui) }}
                {% endif %}
                {% else %}
                  {# 无 system_column: 走 product_to_custom_tag EAV #}
                  {% set pcv = product_custom_tag[field.tag_id] is defined ? product_custom_tag[field.tag_id].value : '' %}
                  {{ eav.renderField(field, pcv, 'product_custom_tag[' ~ field.tag_id ~ '][value]', [], 'cf_' ~ field.tag_id, eav_ui) }}
                {% endif %}
                </div>
                {% endif %}
              {% endfor %}
              {% if struct_final_close|default(0) %}{% for i in 1..struct_final_close %}</fieldset>{% endfor %}{% endif %}
            </fieldset>
          {% endif %}
            
            
            
            
            
            
        </form>
      </div>
    </div>
  </div>
</div>
<script type="text/javascript"><!--
// 商品类型 -> 实时显示/隐藏对应字段: 所有字段 (含系统/核心字段) 一律按 product_type_id 匹配,
// 仅显示当前类型在"商品类型"中配置的字段, 非该类型的字段一律隐藏 (严格按类型作用域)。
// 隐藏用 display:none 而非 disabled -> 隐藏字段仍随表单提交, 其已存值由 setProductTags/editProduct 保留
// (切换类型/编辑不丢数据; 新增商品时隐藏字段提交默认值, 如 status 默认启用)。
function applyProductTypeFields() {
  var T = String($('#input-product-type').val());
  $('#form-product [data-type-id]').each(function() {
    var $el = $(this);
    $el.toggle($el.attr('data-type-id') === T);
  });
}
$(function() {
  $('#input-product-type').on('change', applyProductTypeFields);
  applyProductTypeFields();
  // 防止重复提交: 双击保存会并发触发两次 editProduct, 两次 DELETE+INSERT 交错时
  // 撞 oc_product_description 主键 'pid-lang' 报 Duplicate entry 导致保存失败。
  // 表单 submit 后立即禁用提交按钮, 确保一次只发一次。(校验失败重渲染时按钮自动恢复)
  $('#form-product').on('submit', function() {
    $(this).find('button[type="submit"]').prop('disabled', true);
  });
});
//--></script>
